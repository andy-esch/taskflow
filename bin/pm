# ── Router non-negotiables digest (safety net for agents) ─────────────────

NONNEG_START = "<!-- NON-NEGOTIABLES:START -->"
NONNEG_END = "<!-- NON-NEGOTIABLES:END -->"
ROUTER_FILES = [PLANNING_DIR / "CLAUDE.md", PLANNING_DIR / "GEMINI.md"]


def _extract_nonneg_block(text):
    """Normalized text between the non-negotiables markers, or None if absent."""
    i = text.find(NONNEG_START)
    j = text.find(NONNEG_END)
    if i == -1 or j == -1 or j < i:
        return None
    inner = text[i + len(NONNEG_START) : j]
    return "\n".join(line.rstrip() for line in inner.strip().splitlines())


def _check_router_digest_sync():
    """Advisory string if the digest is missing or differs across routers."""
    blocks = {}
    for p in ROUTER_FILES:
        if not p.exists():
            return f"router file missing: {p.name}"
        block = _extract_nonneg_block(p.read_text())
        if block is None:
            return f"{p.name} is missing the NON-NEGOTIABLES block"
        blocks[p.name] = block
    if len(set(blocks.values())) > 1:
        return "digest differs between " + " / ".join(blocks)
    return None


# ── Handoff-quality heuristics (advisory) ─────────────────────────────────
# A task body is "fresh-AI-executable" if it carries: (1) an acceptance/done
# heading AND at least one checkbox, (2) a concrete code reference, and
# (3) an explicit scope boundary. Regexes are deliberately loose — this is an
# advisory nudge, not a gate; a human/agent triages false positives.

HANDOFF_CHECKBOX_RE = re.compile(r"^\s*[-*] \[[ xX]\]", re.M)
HANDOFF_ACCEPT_RE = re.compile(r"^#{1,6}\s+.*\b(accept|done|success)", re.I | re.M)
HANDOFF_SCOPE_RE = re.compile(
    r"^#{1,6}\s+.*(out[- ]of[- ]scope|non[- ]goals)", re.I | re.M
)
HANDOFF_REF_RE = re.compile(
    r"(packages/|\bbin/pm\b|[\w./-]+\.(py|ts|tsx|go|tf|sql|sh|ya?ml|json|toml)\b)"
)


def _handoff_gaps(body):
    """Labels for missing fresh-AI-handoff signals in a task body ([] if OK)."""
    gaps = []
    if not (HANDOFF_ACCEPT_RE.search(body) and HANDOFF_CHECKBOX_RE.search(body)):
        gaps.append("acceptance")
    if not HANDOFF_REF_RE.search(body):
        gaps.append("file-ref")
    if not HANDOFF_SCOPE_RE.search(body):
        gaps.append("out-of-scope")
    return gaps


def _parse_iso_date(value):
    """Return a datetime.date from value, or None if it isn't a YYYY-MM-DD string."""
    if not value:
        return None
    try:
        return datetime.date.fromisoformat(str(value)[:10])
    except (TypeError, ValueError):
        return None


def _revisit_state(task, today=None):
    """Classify a task by its revisit_after field.

    Returns one of: None (no field), "invalid", "due" (today >= date),
    "waiting" (today < date). Pairs with cmd_index sections + pm list --due.
    """
    val = task.get("revisit_after")
    if not val:
        return None, None
    d = _parse_iso_date(val)
    if d is None:
        return "invalid", str(val)
    today = today or datetime.date.today()
    if d <= today:
        return "due", d
    return "waiting", d


# ── YAML Front Matter Parsing ─────────────────────────────────────────────

FM_RE = re.compile(r"^---\n(.*?)\n---", re.DOTALL)


def parse_front_matter(content):
    """Parse YAML front matter from markdown content. Returns (dict, body)."""
    match = FM_RE.match(content)
    if not match:
        return {}, content

    fm_text = match.group(1)
    body = content[match.end() :].lstrip("\n")

    if yaml:
        try:
            data = yaml.safe_load(fm_text)
            if not isinstance(data, dict):
                data = {}
        except yaml.YAMLError:
            data = _parse_fm_fallback(fm_text)
    else:
        data = _parse_fm_fallback(fm_text)

    # Normalize types
    for k, v in list(data.items()):
        if v is None:
            data[k] = ""
        elif isinstance(v, bool):
            data[k] = str(v).lower()
        elif isinstance(v, (int, float)):
            data[k] = v  # keep numeric

    return data, body


def _parse_fm_fallback(fm_text):
    """Regex-based fallback parser when PyYAML is unavailable.

    Handles inline lists, quoted scalars, and YAML block lists. A block-list
    item becomes a mapping (matching what PyYAML would do, so
    `_list_field_issues` flags it) only when it is unquoted and carries a ': ';
    quoted items keep their colons as plain strings.
    """
    data = {}
    list_key = None  # most recent `key:` with an empty value (awaiting block items)
    for raw in fm_text.split("\n"):
        stripped = raw.strip()
        if not stripped or stripped.startswith("#"):
            continue

        # Block-list item belonging to the previous empty-valued key.
        if (stripped.startswith("- ") or stripped == "-") and list_key is not None:
            item = stripped[1:].strip()
            if len(item) >= 2 and item[0] == item[-1] and item[0] in ('"', "'"):
                item = item[1:-1]
            elif ": " in item:
                # Unquoted colon → PyYAML reads this as a mapping (the bug shape).
                k, v = item.split(":", 1)
                item = {k.strip(): v.strip()}
            if not isinstance(data.get(list_key), list):
                data[list_key] = []
            data[list_key].append(item)
            continue

        if ":" not in stripped:
            list_key = None
            continue

        key, val = stripped.split(":", 1)
        key = key.strip()
        val = val.strip()
        if val == "":
            # Empty value: scalar "" for now, may be upgraded to a block list.
            data[key] = ""
            list_key = key
            continue

        list_key = None
        if val.startswith("[") and val.endswith("]"):
            items = val[1:-1].split(",")
            val = [item.strip().strip("'\"") for item in items if item.strip()]
        elif val.lower() in ("true", "false"):
            val = val.lower()
        else:
            # Strip surrounding quotes
            if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                val = val[1:-1]
        data[key] = val
    return data


def serialize_front_matter(data, body=""):
    """Serialize a dict back to YAML front matter + body."""
    lines = ["---"]
    for k, v in data.items():
        if k.startswith("_"):
            continue
        if isinstance(v, list):
            formatted = "[" + ", ".join(str(i) for i in v) + "]"
            lines.append(f"{k}: {formatted}")
        elif isinstance(v, bool):
            lines.append(f"{k}: {str(v).lower()}")
        else:
            lines.append(f"{k}: {v}")
    lines.append("---")
    result = "\n".join(lines) + "\n"
    if body:
        result += "\n" + body
    return result


def update_front_matter(content, updates, removes=None):
    """Update front matter fields, preserving order and body.

    updates: {key: value} to set (overwrites in place or appends).
    removes: optional iterable of keys to delete entirely. Used for alias
             renames — set the canonical key in updates, drop the old key here.
    """
    removes = set(removes or ())
    match = FM_RE.match(content)
    if not match:
        # No front matter exists — prepend one
        fm = "---\n"
        for k, v in updates.items():
            fm += f"{k}: {v}\n"
        fm += "---\n\n"
        return fm + content

    fm_text = match.group(1)
    rest = content[match.end() :]
    lines = fm_text.split("\n")
    new_lines = []
    keys_updated = set()

    for line in lines:
        if ":" in line and not line.strip().startswith("#"):
            key = line.split(":", 1)[0].strip()
            if key in removes:
                continue
            if key in updates:
                val = updates[key]
                if isinstance(val, list):
                    val = "[" + ", ".join(str(i) for i in val) + "]"
                new_lines.append(f"{key}: {val}")
                keys_updated.add(key)
            else:
                new_lines.append(line)
        else:
            new_lines.append(line)

    for k, v in updates.items():
        if k not in keys_updated:
            if isinstance(v, list):
                v = "[" + ", ".join(str(i) for i in v) + "]"
            new_lines.append(f"{k}: {v}")

    return "---\n" + "\n".join(new_lines) + "\n---" + rest


# ── Task Discovery ─────────────────────────────────────────────────────────


def find_task(task_name):
    """Find a task file by name, slug, or relative path."""
    # Exact path
    path_obj = Path(task_name)
    if path_obj.exists():
        return path_obj.resolve()

    # Relative to planning dir
    root_path = PLANNING_DIR / task_name
    if root_path.exists():
        return root_path

    # Relative to tasks dir (e.g., "ready-to-start/foo.md")
    if "/" in task_name:
        path = TASKS_DIR / task_name
        if path.exists():
            return path

    # Search all status dirs by exact name, then with .md appended
    for subdir in STATUS_DIRS.values():
        path = subdir / task_name
        if path.exists():
            return path
        path = subdir / f"{task_name}.md"
        if path.exists():
            return path

    # Fuzzy: try substring match on stem
    needle = task_name.lower().replace(".md", "")
    candidates = []
    for subdir in STATUS_DIRS.values():
        if not subdir.exists():
            continue
        for f in subdir.glob("*.md"):
            if needle in f.stem.lower():
                candidates.append(f)
    if len(candidates) == 1:
        return candidates[0]
    if len(candidates) > 1:
        print(f"Ambiguous match for '{task_name}'. Candidates:")
        for c in candidates:
            print(f"  {c.relative_to(PLANNING_DIR)}")
        return None

    return None


def get_all_tasks(include_completed=False, include_deprecated=False):
    """Yield (meta_dict) for all tasks. meta has _path, _filename, _status, _body."""
    dirs = ["next-up", "in-progress", "ready-to-start"]
    if include_completed:
        dirs.append("completed")
    if include_deprecated:
        dirs.append("deprecated")

    for d in dirs:
        dir_path = STATUS_DIRS[d]
        if not dir_path.exists():
            continue
        for f in sorted(dir_path.glob("*.md")):
            content = f.read_text(errors="ignore")
            meta, body = parse_front_matter(content)
            meta["_path"] = f
            meta["_filename"] = f.name
            meta["_status"] = d
            meta["_body"] = body
            meta["_content"] = content
            yield meta


def get_valid_epics():
    """Return list of valid epic IDs (filenames without .md)."""
    if not EPICS_DIR.exists():
        return []
    return sorted(f.stem for f in EPICS_DIR.glob("*.md"))


def get_all_epics():
    """Yield epic metadata dicts. Mirrors get_all_tasks but for epics/."""
    if not EPICS_DIR.exists():
        return
    for f in sorted(EPICS_DIR.glob("*.md")):
        content = f.read_text(errors="ignore")
        meta, body = parse_front_matter(content)
        meta["_path"] = f
        meta["_filename"] = f.name
        meta["_id"] = f.stem
        meta["_body"] = body
        meta["_content"] = content
        yield meta


# ── Slug / Filename Helpers ────────────────────────────────────────────────


def slugify(text):
    """Convert text to a clean filename slug."""
    text = text.lower().strip()
    text = re.sub(r"[:\(\)\[\]\{\}'\"!@#$%^&*+=|\\<>,?/~`]", "", text)
    text = re.sub(r"[\s_]+", "-", text)
    text = re.sub(r"-{2,}", "-", text)
    text = text.strip("-")
    # Truncate to reasonable length
    if len(text) > 80:
        text = text[:80].rsplit("-", 1)[0]
    return text


def has_date_prefix(name):
    """Check if a filename starts with YYYY-MM-DD-."""
    return bool(re.match(r"^\d{4}-\d{2}-\d{2}-", name))


def strip_date_prefix(name):
    """Remove leading YYYY-MM-DD- from a filename."""
    return re.sub(r"^\d{4}-\d{2}-\d{2}-", "", name)


# ── Git helpers ────────────────────────────────────────────────────────────


def git_add(path):
    """Stage a file."""
    try:
        subprocess.run(
            ["git", "add", str(path)], check=True, cwd=PLANNING_DIR, capture_output=True
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass


def git_mv(old_path, new_path):
    """Move a file using git mv, falling back to plain rename."""
    if old_path.resolve() == new_path.resolve():
        return
    new_path.parent.mkdir(parents=True, exist_ok=True)
    try:
        # Ensure tracked
        is_tracked = (
            subprocess.run(
                ["git", "ls-files", "--error-unmatch", str(old_path)],
                capture_output=True,
                cwd=PLANNING_DIR,
            ).returncode
            == 0
        )
        if not is_tracked:
            subprocess.run(
                ["git", "add", str(old_path)], capture_output=True, cwd=PLANNING_DIR
            )
        subprocess.run(
            ["git", "mv", str(old_path), str(new_path)],
            check=True,
            cwd=PLANNING_DIR,
            capture_output=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        old_path.rename(new_path)


# ── Commands ───────────────────────────────────────────────────────────────


def cmd_list(args):
    """List tasks with filtering and optional JSON output."""
    include_completed = getattr(args, "status", None) in ("completed", "all")
    include_deprecated = getattr(args, "status", None) in ("deprecated", "all")
    # --due / --waiting need to look at deferred tasks (which live in deprecated/)
    if getattr(args, "due", False) or getattr(args, "waiting", False):
        include_deprecated = True

    tasks = list(get_all_tasks(include_completed, include_deprecated))
    today = datetime.date.today()
    filtered = []

    for t in tasks:
        if args.status and args.status != "all" and t["_status"] != args.status:
            continue
        if args.tag:
            tags = t.get("tags", [])
            if isinstance(tags, str):
                tags = [s.strip() for s in tags.split(",")]
            if args.tag not in tags:
                continue
        if args.epic and t.get("epic") != args.epic:
            continue
        if args.tier and str(t.get("tier", "")) != str(args.tier):
            continue
        if args.priority and t.get("priority") != args.priority:
            continue
        if args.autonomy and str(t.get("autonomy_level", "")) != str(args.autonomy):
            continue
        if args.package:
            tags = t.get("tags", [])
            if isinstance(tags, str):
                tags = [s.strip() for s in tags.split(",")]
            body = t.get("_body", "")
            pkg = args.package.lower()
            if pkg not in [tg.lower() for tg in tags] and f"packages/{pkg}" not in body:
                continue
        if args.search:
            needle = args.search.lower()
            haystack = t.get("_filename", "") + " " + t.get("_content", "")
            if needle not in haystack.lower():
                continue
        if args.quick_wins:
            tier = str(t.get("tier", "9"))
            effort = str(t.get("effort", "")).lower()
            if not (
                tier in ("1", "2")
                and ("min" in effort or "1 hour" in effort or "30" in effort)
            ):
                continue
        if getattr(args, "due", False):
            state, _ = _revisit_state(t, today)
            if state != "due":
                continue
        if getattr(args, "waiting", False):
            state, _ = _revisit_state(t, today)
            if state != "waiting":
                continue
        filtered.append(t)

    if getattr(args, "json", False):
        _output_json(filtered)
        return

    if getattr(args, "oneline", False):
        _print_oneline(filtered)
        return

    _print_task_table(filtered, limit=args.limit)


def _output_json(tasks):
    """Print tasks as JSON (for AI agent consumption)."""
    out = []
    for t in tasks:
        entry = {k: v for k, v in t.items() if not k.startswith("_")}
        entry["file"] = t["_filename"]
        entry["status_dir"] = t["_status"]
        entry["path"] = str(t["_path"].relative_to(PLANNING_DIR))
        out.append(entry)
    print(json.dumps(out, indent=2, default=str))


def _print_task_table(tasks, limit=50):
    """Pretty-print tasks grouped by status."""
    grouped = {}
    for t in tasks:
        s = t["_status"]
        grouped.setdefault(s, []).append(t)

    order = ["next-up", "in-progress", "ready-to-start", "completed", "deprecated"]
    total = 0
    fmt = "  {:<55} {:<5} {:<5} {:<5} {:<18}"

    for status in order:
        items = grouped.get(status)
        if not items:
            continue
        items.sort(key=lambda x: (str(x.get("tier", "9")), str(x.get("priority", "z"))))
        icon = STATUS_ICONS.get(status, "•")

        print(
            f"\n{icon}  {BOLD}{UNDERLINE}{status.upper().replace('-', ' ')}{RESET} ({len(items)})"
        )
        print(f"{BOLD}{fmt.format('TASK', 'TIER', 'PRI', 'AUT', 'EFFORT')}{RESET}")
        print(
            f"{GREY}{fmt.format('─' * 55, '────', '────', '────', '──────────────────')}{RESET}"
        )

        for t in items:
            total += 1
            if limit and total > limit:
                print(f"  … and {len(tasks) - limit} more (use --limit to show more)")
                return

            tier = str(t.get("tier", "·"))
            prio = str(t.get("priority", "·"))[0].upper() if t.get("priority") else "·"
            auto = str(t.get("autonomy_level", "·"))
            effort = str(t.get("effort", ""))[:18]

            tc = RED if tier == "1" else YELLOW if tier == "2" else ""
            ac = GREEN if auto in ("4", "5") else ""

            print(
                fmt.format(
                    t["_filename"][:55],
                    tc + tier + RESET,
                    prio,
                    ac + auto + RESET,
                    effort,
                )
            )
            desc = str(t.get("description") or "").split("\n")[0].strip()
            if desc:
                print(f"  {DIM}{desc[:96]}{RESET}")

    if total == 0:
        print("No tasks found matching filters.")


def _print_oneline(tasks):
    """One line per task: tier, status, filename — description. ANSI-free
    so agents can parse it; pairs with the frontmatter `description` field."""
    order = {
        "next-up": 0,
        "in-progress": 1,
        "ready-to-start": 2,
        "completed": 3,
        "deprecated": 4,
    }
    tasks = sorted(
        tasks, key=lambda t: (order.get(t["_status"], 9), str(t.get("tier", "9")))
    )
    if not tasks:
        print("No tasks found matching filters.")
        return
    for t in tasks:
        tier = str(t.get("tier", "·"))
        desc = str(t.get("description") or "").split("\n")[0].strip()
        if len(desc) > 100:
            desc = desc[:99] + "…"
        line = f"T{tier} {t['_status']:<14} {t['_filename']}"
        if desc:
            line += f" — {desc}"
        print(line)


def cmd_show(args):
    """Display a single task's metadata and body."""
    path = find_task(args.task)
    if not path:
        print(f"❌ Task not found: {args.task}")
        return

    content = path.read_text()
    meta, body = parse_front_matter(content)
    rel = path.relative_to(PLANNING_DIR)

    if getattr(args, "json", False):
        entry = {k: v for k, v in meta.items() if not k.startswith("_")}
        entry["path"] = str(rel)
        entry["body"] = body
        print(json.dumps(entry, indent=2, default=str))
        return

    print(f"\n{BOLD}{CYAN}{'─' * 60}{RESET}")
    print(f"{BOLD}{path.stem}{RESET}")
    print(f"{DIM}{rel}{RESET}")
    print(f"{CYAN}{'─' * 60}{RESET}")

    for k, v in meta.items():
        if k.startswith("_"):
            continue
        if isinstance(v, list):
            v = ", ".join(str(i) for i in v)
        print(f"  {BOLD}{k:<20}{RESET} {v}")

    print(f"{CYAN}{'─' * 60}{RESET}")
    # Show first ~30 lines of body
    lines = body.split("\n")
    for line in lines[:30]:
        print(f"  {line}")
    if len(lines) > 30:
        print(f"\n  {DIM}… ({len(lines) - 30} more lines){RESET}")


def cmd_stats(args):
    """Show project-wide statistics."""
    tasks = list(get_all_tasks(include_completed=True, include_deprecated=True))

    by_status = {}
    by_epic = {}
    by_tier = {}
    by_auto = {}

    for t in tasks:
        s = t["_status"]
        by_status[s] = by_status.get(s, 0) + 1
        e = str(t.get("epic", "unknown"))
        by_epic[e] = by_epic.get(e, 0) + 1
        tier = str(t.get("tier", "?"))
        by_tier[tier] = by_tier.get(tier, 0) + 1
        auto = str(t.get("autonomy_level", "?"))
        by_auto[auto] = by_auto.get(auto, 0) + 1

    if getattr(args, "json", False):
        print(
            json.dumps(
                {
                    "total": len(tasks),
                    "by_status": by_status,
                    "by_epic": by_epic,
                    "by_tier": by_tier,
                    "by_autonomy": by_auto,
                },
                indent=2,
            )
        )
        return

    completed = by_status.get("completed", 0) + by_status.get("deprecated", 0)
    active = len(tasks) - completed

    print(f"\n📊 {BOLD}PROJECT STATISTICS{RESET}")
    print(f"   Total: {len(tasks)}  |  Active: {active}  |  Done: {completed}")

    print(f"\n{BOLD}By Status:{RESET}")
    for s in ["next-up", "in-progress", "ready-to-start", "completed", "deprecated"]:
        if s in by_status:
            bar = "█" * min(by_status[s], 40)
            print(f"  {s:<16} {by_status[s]:>3}  {GREY}{bar}{RESET}")

    print(f"\n{BOLD}By Tier:{RESET}")
    for k in sorted(by_tier.keys()):
        color = RED if k == "1" else YELLOW if k == "2" else ""
        print(f"  Tier {k:<6} {color}{by_tier[k]:>3}{RESET}")

    print(f"\n{BOLD}By Epic:{RESET}")
    for k in sorted(by_epic.keys()):
        bar = "█" * min(by_epic[k], 30)
        print(f"  {k:<38} {by_epic[k]:>3}  {GREY}{bar}{RESET}")


def cmd_tags(args):
    """Tally and list all tags used across active tasks."""
    tasks = list(get_all_tasks(include_completed=False, include_deprecated=False))
    tag_counts = {}
    for t in tasks:
        tags = t.get("tags", [])
        if isinstance(tags, str):
            tags = [s.strip() for s in tags.split(",")]
        for tag in tags:
            tag = tag.strip()
            if tag:
                tag_counts[tag] = tag_counts.get(tag, 0) + 1

    # Sort: count desc, then name asc
    sorted_tags = sorted(tag_counts.items(), key=lambda x: (-x[1], x[0]))

    if getattr(args, "json", False):
        print(json.dumps(dict(sorted_tags), indent=2))
        return

    print(f"\n🏷️  {BOLD}TAG VOCABULARY{RESET} ({len(tag_counts)} distinct tags)")
    print(f"{GREY}{'─' * 30}{RESET}")
    for tag, count in sorted_tags:
        print(f"  {tag:<24} {count:>3}")


# ── Epic Commands ──────────────────────────────────────────────────────────


def cmd_epic_list(args):
    """List all epics with task rollup counts."""
    epics_meta = {e["_id"]: e for e in get_all_epics()}
    epics = sorted(epics_meta.keys())
    tasks = list(get_all_tasks(include_completed=True, include_deprecated=True))

    # Group tasks by epic
    by_epic = {}
    for t in tasks:
        e = str(t.get("epic", ""))
        by_epic.setdefault(e, []).append(t)

    if getattr(args, "json", False):
        out = []
        for eid in epics:
            epic_tasks = by_epic.get(eid, [])
            statuses = {}
            for t in epic_tasks:
                statuses[t["_status"]] = statuses.get(t["_status"], 0) + 1
            em = epics_meta[eid]
            out.append(
                {
                    "id": eid,
                    "status": em.get("status", ""),
                    "description": em.get("description", ""),
                    "priority": em.get("priority", ""),
                    "tags": em.get("tags", []),
                    "tasks": len(epic_tasks),
                    **statuses,
                }
            )
        print(json.dumps(out, indent=2, default=str))
        return

    fmt = "  {:<42} {:>5} {:>5} {:>5} {:>5} {:>5}"
    print(f"\n{BOLD}EPICS{RESET}")
    print(f"{BOLD}{fmt.format('EPIC', 'TOTAL', 'NEXT', 'WIP', 'READY', 'DONE')}{RESET}")
    print(
        f"{GREY}{fmt.format('─' * 42, '─' * 5, '─' * 5, '─' * 5, '─' * 5, '─' * 5)}{RESET}"
    )

    for eid in epics:
        epic_tasks = by_epic.get(eid, [])
        total = len(epic_tasks)
        nu = sum(1 for t in epic_tasks if t["_status"] == "next-up")
        ip = sum(1 for t in epic_tasks if t["_status"] == "in-progress")
        rs = sum(1 for t in epic_tasks if t["_status"] == "ready-to-start")
        done = sum(1 for t in epic_tasks if t["_status"] in ("completed", "deprecated"))
        pct = f" ({done * 100 // total}%)" if total else ""

        print(fmt.format(eid, total, nu or "·", ip or "·", rs or "·", f"{done}{pct}"))
        desc = str(epics_meta[eid].get("description") or "").split("\n")[0].strip()
        if desc:
            print(f"      {DIM}{desc[:96]}{RESET}")

    # Show orphaned tasks (epic not in epics/)
    orphaned = sorted({e for e in by_epic if e and e not in epics and e != "unknown"})
    if orphaned:
        print(
            f"\n{YELLOW}⚠ Tasks reference unknown epics: {', '.join(orphaned)}{RESET}"
        )
        print(f"  {DIM}Run `pm epic orphans` for the affected tasks.{RESET}")


def cmd_epic_show(args):
    """Show a single epic's details and its tasks."""
    eid = args.epic_id
    # Try to match partial epic ID
    epics = get_valid_epics()
    matches = [e for e in epics if eid in e]
    if not matches:
        print(f"❌ Epic not found: {eid}")
        return
    if len(matches) > 1:
        exact = [e for e in matches if e == eid]
        if exact:
            matches = exact
        else:
            print(f"Ambiguous. Matches: {', '.join(matches)}")
            return

    eid = matches[0]
    epic_path = EPICS_DIR / f"{eid}.md"
    meta, body = parse_front_matter(epic_path.read_text())

    tasks = [
        t
        for t in get_all_tasks(include_completed=True, include_deprecated=True)
        if t.get("epic") == eid
    ]

    if getattr(args, "json", False):
        out = {k: v for k, v in meta.items() if not k.startswith("_")}
        out["id"] = eid
        out["tasks"] = [
            {"file": t["_filename"], "status": t["_status"], "tier": t.get("tier")}
            for t in tasks
        ]
        print(json.dumps(out, indent=2, default=str))
        return

    print(f"\n{BOLD}{CYAN}{'═' * 60}{RESET}")
    print(f"{BOLD}Epic: {eid}{RESET}")
    if meta.get("status"):
        print(f"Status: {meta['status']}")
    print(f"{CYAN}{'═' * 60}{RESET}")

    # Show body excerpt
    lines = body.split("\n")
    for line in lines[:15]:
        print(f"  {line}")
    if len(lines) > 15:
        print(
            f"\n  {DIM}… ({len(lines) - 15} more lines in {epic_path.relative_to(PLANNING_DIR)}){RESET}"
        )

    print(f"\n{BOLD}Tasks ({len(tasks)}):{RESET}")
    for status in [
        "next-up",
        "in-progress",
        "ready-to-start",
        "completed",
        "deprecated",
    ]:
        group = [t for t in tasks if t["_status"] == status]
        if not group:
            continue
        icon = STATUS_ICONS.get(status, "•")
        print(f"\n  {icon} {BOLD}{status}{RESET} ({len(group)})")
        for t in group[:10]:
            tier = str(t.get("tier", "·"))
            print(f"    {tier}  {t['_filename']}")
        if len(group) > 10:
            print(f"    {DIM}… and {len(group) - 10} more{RESET}")


def cmd_epic_lint(args):
    """Validate epic frontmatter. With --fix, auto-repair alias renames."""
    fix = getattr(args, "fix", False)
    epics = list(get_all_epics())
    issues_total = 0
    fixed_total = 0

    _sch = _build_epic_schema()
    known_fields = (
        set(_sch["required"])
        | set(_sch["recommended"])
        | set(_sch["optional"])
        | set(_sch["aliases"].keys())
        | set(_sch["aliases"].values())
    )
    unknown_fields = {}

    print(f"\n🔍 {BOLD}EPIC LINT: {len(epics)} epics{RESET}")
    if fix:
        print(f"   {YELLOW}--fix mode: alias renames will be applied{RESET}")

    for e in epics:
        path = e["_path"]
        content = e["_content"]
        meta = {k: v for k, v in e.items() if not k.startswith("_")}
        local_issues = []
        fixes = {}
        renames = set()

        # Required fields
        for f in EPIC_REQUIRED_FIELDS:
            if not meta.get(f):
                local_issues.append(f"missing '{f}'")

        # Constrained status
        st = meta.get("status")
        if st and st not in VALID_EPIC_STATUSES:
            allowed = ", ".join(sorted(VALID_EPIC_STATUSES))
            local_issues.append(f"unknown status '{st}' (valid: {allowed})")

        # Description quality
        desc = meta.get("description")
        if desc:
            ds = str(desc)
            if "\n" in ds:
                local_issues.append("'description' must be a single line")
            elif len(ds) > 200:
                local_issues.append(
                    f"'description' too long ({len(ds)} chars; keep ≤200)"
                )

        # Alias renames (auto-fixable)
        for old_name, new_name in EPIC_FIELD_ALIASES.items():
            if old_name not in meta:
                continue
            # Bare "completed"/"started" are only date aliases when they hold dates
            if old_name in ("completed", "started"):
                cv = meta.get(old_name)
                if not (
                    isinstance(cv, str) and re.match(r"\d{4}-\d{2}-\d{2}", str(cv))
                ):
                    continue
            if new_name in meta:
                local_issues.append(
                    f"has both '{old_name}' and '{new_name}' — drop '{old_name}' manually"
                )
                continue
            local_issues.append(f"rename '{old_name}' → '{new_name}'")
            fixes[new_name] = meta[old_name]
            renames.add(old_name)

        # Unknown fields (advisory)
        for _k in meta:
            if (
                not _k.startswith("_")
                and _k not in known_fields
                and re.match(r"^[A-Za-z][\w-]*$", str(_k))
            ):
                unknown_fields[_k] = unknown_fields.get(_k, 0) + 1

        if local_issues:
            issues_total += 1
            print(f"\n{'❌' if not fix else '🔧'} {e['_filename']}")
            for issue in local_issues:
                actionable = issue.startswith("rename")
                print(f"   {'→' if fix and actionable else '·'} {issue}")
            if fix and (fixes or renames):
                new_content = update_front_matter(content, fixes, removes=renames)
                path.write_text(new_content)
                git_add(path)
                fixed_total += 1
                print(f"   {GREEN}✓ Renamed {len(renames)} field(s){RESET}")

    if unknown_fields:
        _top = sorted(unknown_fields.items(), key=lambda x: (-x[1], x[0]))
        _shown = ", ".join(f"{k}({v})" for k, v in _top[:12])
        print(
            f"\n{DIM}ℹ {len(unknown_fields)} unrecognized field name(s) in epics: "
            f"{_shown}. Advisory only.{RESET}"
        )

    if issues_total == 0:
        print(f"\n{GREEN}✅ All {len(epics)} epics pass lint.{RESET}")
    else:
        print(f"\n{'🔧' if fix else '❌'} {issues_total} epics with issues")
        if fix:
            print(
                f"   {GREEN}Fixed {fixed_total} automatically. Missing required "
                f"fields (description/created/tags) need manual fill.{RESET}"
            )
        else:
            print(f"   Run {BOLD}pm epic lint --fix{RESET} to apply alias renames.")


def cmd_epic_new(args):
    """Scaffold a new epic with standardized frontmatter and body skeleton."""
    # Next epic number
    existing = sorted(EPICS_DIR.glob("*.md"))
    next_num = 1
    for f in existing:
        m = re.match(r"^(\d+)-", f.name)
        if m:
            next_num = max(next_num, int(m.group(1)) + 1)

    slug = slugify(args.title)
    if not slug:
        print(f"❌ Title produced an empty slug: '{args.title}'")
        return
    filename = f"{next_num:02d}-{slug}.md"
    path = EPICS_DIR / filename
    if path.exists():
        print(f"❌ Already exists: {path.relative_to(PLANNING_DIR)}")
        return

    desc = (args.description or "").strip()
    if not desc:
        print("❌ --description is required (≤150 chars, single line).")
        return
    if "\n" in desc:
        print("❌ --description must be a single line.")
        return
    if len(desc) > 150:
        print(f"❌ --description too long ({len(desc)} chars; keep ≤150).")
        return

    status = args.status or "planning"
    if status not in VALID_EPIC_STATUSES:
        print(f"❌ --status must be one of: {', '.join(sorted(VALID_EPIC_STATUSES))}")
        return

    priority = args.priority or "medium"
    if priority not in VALID_PRIORITIES:
        print(f"❌ --priority must be one of: {', '.join(sorted(VALID_PRIORITIES))}")
        return

    tags = [t.strip() for t in (args.tags or "").split(",") if t.strip()]

    meta = {
        "status": status,
        "description": desc,
        "created": datetime.date.today().isoformat(),
        "tags": tags,
        "priority": priority,
    }
    if args.owner:
        meta["owner"] = args.owner

    title_for_h1 = args.title.strip()
    body = textwrap.dedent(f"""\
        # Epic {next_num}: {title_for_h1}

        **Goal.** {desc}

        ## Why this is its own epic

        <!-- One paragraph: what makes this a separate epic vs folding into a
        sibling? Cross-cutting scope? Long-lived architectural decision?
        Different stakeholders? Delete this section if obvious from the goal. -->

        ## Current state

        <!-- What exists today that callers should not re-propose. Cite paths
        with `relative/path.go:line` so a cold agent can verify. -->

        ## Out of scope / Non-goals

        <!-- Things adjacent reviewers will assume are in scope but are not. -->

        ## References

        <!-- Related research docs, ADRs, issues, sibling epics. -->
        """)

    content = serialize_front_matter(meta, body)
    path.write_text(content)
    git_add(path)
    print(f"✅ Created: {path.relative_to(PLANNING_DIR)}")
    print(f"   Epic ID: {path.stem}")


def cmd_epic_orphans(args):
    """List active tasks referencing unknown epic IDs."""
    valid = set(get_valid_epics())
    include_archived = getattr(args, "include_archived", False)
    tasks = list(
        get_all_tasks(
            include_completed=include_archived,
            include_deprecated=include_archived,
        )
    )

    orphans = []
    for t in tasks:
        eid = str(t.get("epic", "") or "")
        if not eid:
            orphans.append((t, "<missing>"))
        elif eid not in valid:
            orphans.append((t, eid))

    if getattr(args, "json", False):
        print(
            json.dumps(
                [
                    {
                        "file": t["_filename"],
                        "status_dir": t["_status"],
                        "epic": eid,
                        "tier": t.get("tier"),
                        "description": t.get("description", ""),
                    }
                    for t, eid in orphans
                ],
                indent=2,
                default=str,
            )
        )
        return

    label = "active tasks" if not include_archived else "tasks (incl. archived)"
    if not orphans:
        print(f"\n{GREEN}✅ No orphaned {label}.{RESET}")
        return

    by_epic = {}
    for t, eid in orphans:
        by_epic.setdefault(eid, []).append(t)

    print(f"\n{BOLD}🔗 ORPHANED TASKS{RESET}  ({len(orphans)} {label})")
    print(f"{DIM}Tasks whose `epic:` field doesn't match any file in epics/{RESET}")

    for eid in sorted(by_epic):
        group = by_epic[eid]
        print(
            f"\n  {YELLOW}epic={eid}{RESET}  ({len(group)} task{'s' if len(group) != 1 else ''})"
        )
        for t in sorted(group, key=lambda x: (x["_status"], x["_filename"])):
            print(f"    {t['_status']:<14} {t['_filename']}")

    print(
        f"\n  {DIM}Fix with: pm set <task> epic <valid-epic-id>"
        f" (see pm epic list for valid IDs){RESET}"
    )


# ── Set / Edit Frontmatter ─────────────────────────────────────────────────


def _list_field_issues(meta):
    """Lint errors for known list fields whose entries parsed as non-scalars.

    A YAML block-list item containing ': ' parses as a mapping
    (`- foo: bar` -> {'foo': 'bar'}), silently mangling the field. Flag it so
    `pm lint` catches the breakage that otherwise only shows up as a garbled
    `pm show --json` shape.
    """
    issues = []
    # Shape A (PyYAML available): the item parses as a mapping nested in the list.
    for field in KNOWN_LIST_FIELDS:
        val = meta.get(field)
        if not isinstance(val, list):
            continue
        for entry in val:
            if isinstance(entry, (dict, list)):
                issues.append(
                    f"'{field}' has a non-scalar entry {entry!r} — a list item "
                    f"with a colon parses as a mapping; quote it or drop the colon"
                )
    # Shape B (regex fallback parser): the item leaks out as a bogus top-level
    # key beginning with '-' (e.g. '- refactor-foo'), leaving its real field "".
    for key in meta:
        if isinstance(key, str) and key.lstrip().startswith("-"):
            issues.append(
                f"frontmatter key {key!r} looks like a mangled YAML list item "
                f"(a list entry with a colon parsed as a key); fix the offending "
                f"list field"
            )
    return issues


def validate_field(field, value):
    """Validate a field value against known constraints. Returns (ok, error_msg)."""
    if field in CONSTRAINED_FIELDS:
        hint, check = CONSTRAINED_FIELDS[field]
        str_val = str(value)
        # For epic, try partial match
        if field == "epic" and not check(str_val):
            epics = get_valid_epics()
            matches = [e for e in epics if str_val in e]
            if len(matches) == 1:
                return True, matches[0]  # return resolved value
            elif matches:
                return (
                    False,
                    f"Ambiguous epic '{str_val}'. Matches: {', '.join(matches)}",
                )
            else:
                return False, f"Unknown epic: {str_val}. Valid: {', '.join(epics)}"
        if not check(str_val):
            return False, f"Invalid {field}: '{str_val}' (must be {hint})"
    return True, None


def _set_value_issue(field, value, path):
    """Write-time checks for `pm set` beyond CONSTRAINED_FIELDS (§4).

    Returns an error string (caller must not write) or None. Mirrors the lint
    rules so a value that would fail `pm lint` can't be written silently.
    """
    if field == "description":
        sval = str(value)
        if "\n" in sval:
            return "'description' must be a single line"
        if len(sval) > 150:
            return f"'description' too long ({len(sval)} chars; keep ≤150)"
    if field == "status":
        dir_status = path.parent.name
        if dir_status in VALID_STATUSES and str(value) != dir_status:
            return (
                f"status '{value}' != directory '{dir_status}'; use "
                f"pm start/next/complete/defer/deprecate to move the file"
            )
    return None


def cmd_set(args):
    """Set a frontmatter field on a task (with validation)."""
    path = find_task(args.task)
    if not path:
        print(f"❌ Task not found: {args.task}")
        return

    field = args.field
    value = args.value

    # Normalize aliased field names before writing (mirror lint --fix). The bare
    # `completed` alias only resolves when the value is a date.
    if field in FIELD_ALIASES and not (
        field == "completed" and not re.match(r"\d{4}-\d{2}-\d{2}", str(value))
    ):
        canonical = FIELD_ALIASES[field]
        print(f"   Normalized field name: {field} → {canonical}")
        field = canonical

    # Parse value: detect lists
    if value.startswith("[") and value.endswith("]"):
        value = [v.strip().strip("'\"") for v in value[1:-1].split(",") if v.strip()]
    else:
        # Validate scalar fields
        ok, result = validate_field(field, value)
        if not ok:
            print(f"❌ {result}")
            return
        # Use resolved value (e.g. partial epic match)
        if result is not None:
            value = result
            print(f"   Matched: {value}")

        # Write-time validation (§4): refuse values that would fail lint.
        err = _set_value_issue(field, value, path)
        if err:
            print(f"❌ {err} — not written.")
            return

    content = path.read_text()
    updates = {field: value}
    if field != "updated_at":
        updates["updated_at"] = datetime.date.today().isoformat()
    new_content = update_front_matter(content, updates)
    path.write_text(new_content)
    git_add(path)
    print(f"✅ Set {field}={value} on {path.name}")


def cmd_touch(args):
    """Update updated_at = today for one or more tasks."""
    today = datetime.date.today().isoformat()
    for task in args.tasks:
        path = find_task(task)
        if not path:
            print(f"❌ Task not found: {task}")
            continue
        content = path.read_text()
        new_content = update_front_matter(content, {"updated_at": today})
        path.write_text(new_content)
        git_add(path)
        print(f"✅ Touched {path.name} (updated_at={today})")


# ── Lint / Validate ────────────────────────────────────────────────────────


def cmd_lint(args):
    """Validate task frontmatter. With --fix, auto-repair common issues."""
    fix = getattr(args, "fix", False)
    include_archived = getattr(args, "include_archived", False)
    errors_only = getattr(args, "errors_only", False)
    only_tasks = getattr(args, "tasks", None) or []
    tasks = list(
        get_all_tasks(
            include_completed=include_archived, include_deprecated=include_archived
        )
    )
    if only_tasks:
        wanted = set()
        for name in only_tasks:
            p = find_task(name)
            if not p:
                print(f"❌ Task not found: {name}")
                continue
            wanted.add(p.resolve())
        tasks = [t for t in tasks if t["_path"].resolve() in wanted]
        # Per-file mode: advisories are noise when you're fixing one task.
        errors_only = True
    valid_epics = get_valid_epics()
    issues_total = 0
    fixed_total = 0
    missing_desc_soft = 0
    # #7 drift visibility: known field set shared with `pm schema`
    _sch = _build_schema()
    known_fields = (
        set(_sch["required"])
        | set(_sch["recommended"])
        | set(_sch["optional"])
        | set(_sch["aliases"].keys())
        | set(_sch["aliases"].values())
    )
    unknown_fields = {}
    handoff_check = not getattr(args, "no_handoff_check", False)
    handoff_gaps = {}  # filename -> [missing labels]

    label = "active tasks" if not include_archived else "tasks (including archived)"
    print(f"\n🔍 {BOLD}LINT: {len(tasks)} {label}{RESET}")
    if fix:
        print(f"   {YELLOW}--fix mode: will auto-repair where possible{RESET}")

    for t in tasks:
        path = t["_path"]
        content = path.read_text()
        meta, body = parse_front_matter(content)
        local_issues = []
        fixes = {}
        renames = set()
        is_archived = t["_status"] in ("completed", "deprecated")

        if handoff_check and not is_archived:
            _hg = _handoff_gaps(body)
            if _hg:
                handoff_gaps[t["_filename"]] = _hg

        for _k in meta:
            # Only real field-name identifiers — guards against the regex
            # fallback parser mis-reading YAML block-list items as keys.
            if (
                not _k.startswith("_")
                and _k not in known_fields
                and re.match(r"^[A-Za-z][\w-]*$", str(_k))
            ):
                unknown_fields[_k] = unknown_fields.get(_k, 0) + 1

        # Check required fields
        if not meta.get("status"):
            local_issues.append("missing 'status'")
            if not is_archived:
                fixes["status"] = t["_status"]
        elif meta["status"] != t["_status"]:
            local_issues.append(
                f"status '{meta['status']}' != directory '{t['_status']}'"
            )
            if not is_archived:
                fixes["status"] = t["_status"]

        if not meta.get("epic"):
            local_issues.append("missing 'epic'")
        elif valid_epics and str(meta["epic"]) not in valid_epics:
            local_issues.append(f"unknown epic: {meta['epic']}")

        if not meta.get("tier"):
            local_issues.append("missing 'tier'")
        if not meta.get("effort"):
            local_issues.append("missing 'effort'")
        if not meta.get("priority"):
            local_issues.append("missing 'priority'")
            if not is_archived:
                fixes["priority"] = "medium"
        if not meta.get("autonomy_level") and not meta.get("gemini_autonomy"):
            local_issues.append("missing 'autonomy_level'")
            if not is_archived:
                fixes["autonomy_level"] = 3
        if not meta.get("tags"):
            local_issues.append("missing 'tags'")
            if not is_archived:
                fixes["tags"] = []
        if not meta.get("created") and not meta.get("created_date"):
            local_issues.append("missing 'created'")
            if not is_archived:
                fixes["created"] = datetime.date.today().isoformat()

        # Normalize field aliases (rename old → canonical, dropping the old key)
        for old_name, new_name in FIELD_ALIASES.items():
            if old_name not in meta:
                continue
            # Bare "completed" is only a completed_at alias when it holds a date
            if old_name == "completed":
                cv = meta.get("completed")
                if not (
                    isinstance(cv, str) and re.match(r"\d{4}-\d{2}-\d{2}", str(cv))
                ):
                    continue
            if new_name in meta:
                local_issues.append(
                    f"has both '{old_name}' and '{new_name}' — drop '{old_name}' manually"
                )
                continue
            local_issues.append(f"rename '{old_name}' → '{new_name}'")
            fixes[new_name] = meta[old_name]
            renames.add(old_name)

        # Soft check: description (enforced for next-up/in-progress, else advisory)
        desc = meta.get("description")
        if not desc:
            if not is_archived and t["_status"] in ("next-up", "in-progress"):
                local_issues.append(
                    "missing 'description' (required for next-up/in-progress)"
                )
            elif not is_archived:
                missing_desc_soft += 1
        else:
            ds = str(desc)
            if "\n" in ds:
                local_issues.append("'description' must be a single line")
            elif len(ds) > 150:
                local_issues.append(
                    f"'description' too long ({len(ds)} chars; keep ≤150)"
                )

        # Validate revisit_after format (only if set — field is optional)
        ra = meta.get("revisit_after")
        if ra and _parse_iso_date(ra) is None:
            local_issues.append(f"'revisit_after' must be YYYY-MM-DD, got '{ra}'")

        # Reject list fields mangled into mappings (colon-in-item) — §1
        local_issues.extend(_list_field_issues(meta))

        # Check filename issues
        if ":" in t["_filename"]:
            local_issues.append(f"colon in filename (breaks shell)")
        if len(t["_filename"]) > 100:
            local_issues.append(f"filename too long ({len(t['_filename'])} chars)")
        if has_date_prefix(t["_filename"]) and t["_status"] not in (
            "completed",
            "deprecated",
        ):
            local_issues.append("date prefix on non-completed file")

        if local_issues:
            issues_total += 1
            status_badge = f"{GREY}[{t['_status']}]{RESET}"
            print(f"\n{'❌' if not fix else '🔧'} {t['_filename']} {status_badge}")
            for issue in local_issues:
                actionable = issue.startswith("missing") or issue.startswith("rename")
                print(f"   {'→' if fix and actionable else '·'} {issue}")

            if fix and (fixes or renames):
                new_content = update_front_matter(content, fixes, removes=renames)
                path.write_text(new_content)
                git_add(path)
                fixed_total += 1
                print(f"   {GREEN}✓ Fixed {len(fixes) + len(renames)} field(s){RESET}")

    # ── Advisories (grouped after the hard errors; hidden by --errors-only) ──
    advisories = []
    if missing_desc_soft:
        advisories.append(
            f"{DIM}ℹ {missing_desc_soft} ready-to-start task(s) missing 'description' "
            f"(advisory — backfill recommended).{RESET}"
        )

    if unknown_fields:
        _top = sorted(unknown_fields.items(), key=lambda x: (-x[1], x[0]))
        _shown = ", ".join(f"{k}({v})" for k, v in _top[:12])
        _more = "" if len(_top) <= 12 else f", +{len(_top) - 12} more"
        advisories.append(
            f"{DIM}ℹ {len(unknown_fields)} unrecognized field name(s) "
            f"(not in `pm schema`): {_shown}{_more}.\n"
            f"  Intentional extensions are fine — fix typos, or add stable ones "
            f"to OPTIONAL_FIELDS. Advisory only; never auto-fixed.{RESET}"
        )

    if handoff_gaps:
        _items = sorted(handoff_gaps.items())
        _shown = "; ".join(f"{f} ({'+'.join(g)})" for f, g in _items[:8])
        _more = "" if len(_items) <= 8 else f"; +{len(_items) - 8} more"
        advisories.append(
            f"{DIM}ℹ {len(handoff_gaps)} active task(s) not fresh-AI-handoff "
            f"ready (missing acceptance/file-ref/out-of-scope):\n"
            f"  {_shown}{_more}.\n"
            f"  Advisory only — see `pm schema`; opt out with "
            f"`pm lint --no-handoff-check`.{RESET}"
        )

    digest_issue = _check_router_digest_sync()
    if digest_issue:
        advisories.append(
            f"{DIM}ℹ Router non-negotiables digest: {digest_issue}. "
            f"Edit the NON-NEGOTIABLES block identically in CLAUDE.md & "
            f"GEMINI.md (advisory).{RESET}"
        )

    if advisories and not errors_only:
        print(f"\n{DIM}─── ADVISORIES (hide with --errors-only) ───{RESET}")
        for a in advisories:
            print(f"\n{a}")

    if issues_total == 0:
        print(f"\n{GREEN}✅ All {len(tasks)} {label} pass lint.{RESET}")
    else:
        print(f"\n{'🔧' if fix else '❌'} {issues_total} tasks with issues")
        if fix:
            print(
                f"   {GREEN}Fixed {fixed_total} automatically. Some issues need manual attention.{RESET}"
            )
        elif issues_total > 0:
            print(f"   Run {BOLD}pm lint --fix{RESET} to auto-repair where possible.")


# ── Schema ─────────────────────────────────────────────────────────────────

# Documented optional fields (not enforced, but recognized/expected).
OPTIONAL_FIELDS = [
    "related_tasks",
    "dependencies",
    "blocked_by",
    "blocks",
    "started_at",
    "completed_at",
    "updated_at",
    "deprecated_at",
    "deprecated_reason",
    "deferred_at",
    "deferred_reason",
    "revisit_after",
    "revisit_reason",
    "project",
    "sprint_name",
    "sprint_sequence",
    "audited",
    "audit_sources",
]


def _build_schema():
    """Single source of truth for the task frontmatter schema."""
    return {
        "required": REQUIRED_FIELDS,
        "recommended": ["description"],
        "optional": OPTIONAL_FIELDS,
        "aliases": dict(FIELD_ALIASES),
        "constrained": {
            "status": sorted(VALID_STATUSES),
            "priority": sorted(VALID_PRIORITIES),
            "tier": sorted(VALID_TIERS),
            "autonomy_level": sorted(VALID_AUTONOMY),
        },
        "known_packages": KNOWN_PACKAGES,
        "notes": {
            "description": "One-line summary (\u2264150 chars, no newlines). "
            "Surfaces in `pm list --json/--oneline` so agents "
            "can triage without reading each task body. "
            "Required for next-up/in-progress.",
            "tags": "Freeform list. Run `./bin/pm tags` for the live vocabulary "
            "to reuse existing tags rather than coining synonyms.",
            "body": "Fresh-AI-handoff standard: a task body should carry an "
            "acceptance/done heading with at least one checkbox, at "
            "least one concrete code reference, and an explicit "
            "out-of-scope/non-goals section. `pm lint` emits an "
            "advisory (opt out: `pm lint --no-handoff-check`).",
            "revisit_after": "YYYY-MM-DD. Set on a next-up/in-progress task "
            "that's time-gated (e.g., waiting on metrics to "
            "saturate, waiting for a vendor response). "
            "`pm` (dashboard) surfaces it in 'Waiting' until "
            "the date passes, then in 'Ready to revisit'. "
            "`pm list --due` filters to ready ones. Also set "
            "by `pm defer --revisit` on deferred tasks.",
        },
    }


def _build_epic_schema():
    """Single source of truth for the epic frontmatter schema."""
    return {
        "required": EPIC_REQUIRED_FIELDS,
        "recommended": EPIC_RECOMMENDED_FIELDS,
        "optional": EPIC_OPTIONAL_FIELDS,
        "aliases": dict(EPIC_FIELD_ALIASES),
        "constrained": {
            "status": sorted(VALID_EPIC_STATUSES),
            "priority": sorted(VALID_PRIORITIES),
        },
        "notes": {
            "description": "One-line summary of the epic goal (\u2264150 chars, "
            "no newlines). Surfaces in `pm epic list` and "
            "`pm epic list --json` so agents can pick the "
            "right home for a new task without reading each "
            "epic body. Required.",
            "status_mapping": "Historical *-complete variants "
            "(functionally-complete, core-complete, "
            "mostly-complete) collapse to `complete`. "
            "`research` collapses to `planning`. "
            "`pm epic lint --fix` does NOT auto-collapse "
            "these (semantics differ per epic).",
            "body": "Recommended sections: Goal, Why this is its own epic "
            "(if non-obvious), Current state, Out of scope / Non-goals, "
            "References. Do NOT hand-maintain a `## Tasks` list of "
            "filenames \u2014 `pm epic show` already enumerates tasks from "
            "frontmatter.",
        },
    }


def cmd_schema(args):
    """Print the task/epic frontmatter schema (the contract for humans + agents)."""
    target = getattr(args, "type", None) or "task"
    if target not in ("task", "epic", "all"):
        print(f"❌ --type must be one of: task, epic, all")
        return

    task_schema = _build_schema()
    epic_schema = _build_epic_schema()

    if getattr(args, "json", False):
        if target == "task":
            print(json.dumps(task_schema, indent=2, default=str))
        elif target == "epic":
            print(json.dumps(epic_schema, indent=2, default=str))
        else:
            print(
                json.dumps(
                    {"task": task_schema, "epic": epic_schema}, indent=2, default=str
                )
            )
        return

    if target in ("task", "all"):
        _print_schema_block(
            "TASK FRONTMATTER SCHEMA",
            task_schema,
            include_packages=True,
            body_label="Task body (handoff)",
        )

    if target in ("epic", "all"):
        if target == "all":
            print()  # spacing
        _print_schema_block(
            "EPIC FRONTMATTER SCHEMA",
            epic_schema,
            include_packages=False,
            body_label="Epic body (conventions)",
        )


def _print_schema_block(title, schema, include_packages=False, body_label="Body"):
    print(f"\n{BOLD}{title}{RESET}")
    print(f"\n{BOLD}Required{RESET}:")
    for f in schema["required"]:
        note = schema["notes"].get(f, "") if f in schema.get("notes", {}) else ""
        suffix = f"  {DIM}{note}{RESET}" if note else ""
        print(f"  • {f}{suffix}")
    if schema.get("recommended"):
        print(f"\n{BOLD}Recommended{RESET}:")
        for f in schema["recommended"]:
            note = schema["notes"].get(f, "")
            suffix = f"  {DIM}{note}{RESET}" if note else ""
            print(f"  • {f}{suffix}")
    if schema.get("optional"):
        print(f"\n{BOLD}Optional{RESET} (recognized):")
        print(f"  {DIM}{', '.join(schema['optional'])}{RESET}")
    if schema["notes"].get("tags"):
        print(f"\n{BOLD}Tags{RESET}")
        print(f"  {DIM}{schema['notes']['tags']}{RESET}")
    if schema["notes"].get("body"):
        print(f"\n{BOLD}{body_label}{RESET}")
        print(f"  {DIM}{schema['notes']['body']}{RESET}")
    if schema["notes"].get("status_mapping"):
        print(f"\n{BOLD}Status mapping{RESET}")
        print(f"  {DIM}{schema['notes']['status_mapping']}{RESET}")
    print(f"\n{BOLD}Constrained values:{RESET}")
    for k, vals in schema["constrained"].items():
        print(f"  {k:<16} {', '.join(str(v) for v in vals)}")
    print(f"\n{BOLD}Aliases{RESET} (auto-normalized by lint --fix):")
    for old, new in schema["aliases"].items():
        print(f"  {old:<18} → {new}")
    if include_packages and schema.get("known_packages"):
        print(f"\n{BOLD}Known packages:{RESET}")
        print(f"  {DIM}{', '.join(schema['known_packages'])}{RESET}")


# ── Rename / Slug Normalization ────────────────────────────────────────────


def cmd_rename(args):
    """Normalize a task filename (remove colons, truncate, slugify)."""
    if args.task == "--all":
        _rename_all(dry_run=args.dry_run)
        return

    path = find_task(args.task)
    if not path:
        print(f"❌ Task not found: {args.task}")
        return

    _rename_one(path, dry_run=args.dry_run)


def _rename_one(path, dry_run=False):
    """Rename a single file to a clean slug."""
    old_name = path.name
    stem = path.stem
    # Strip date prefix if present and not in completed/deprecated
    parent_name = path.parent.name
    if has_date_prefix(stem) and parent_name not in ("completed", "deprecated"):
        stem = strip_date_prefix(stem)
    new_name = slugify(stem) + ".md"

    if new_name == old_name:
        return False

    new_path = path.parent / new_name
    if new_path.exists():
        print(f"  ⚠️  Can't rename {old_name} → {new_name} (target exists)")
        return False

    if dry_run:
        print(f"  {old_name}")
        print(f"  → {new_name}")
        return True

    git_mv(path, new_path)
    git_add(new_path)
    print(f"  ✅ {old_name}")
    print(f"   → {new_name}")
    return True


def _rename_all(dry_run=False):
    """Find and rename all files with problematic names."""
    count = 0
    for subdir in STATUS_DIRS.values():
        if not subdir.exists():
            continue
        for f in sorted(subdir.glob("*.md")):
            name = f.name
            needs_rename = (
                ":" in name
                or len(name) > 100
                or (
                    has_date_prefix(name)
                    and subdir.name not in ("completed", "deprecated")
                )
            )
            if needs_rename:
                if _rename_one(f, dry_run=dry_run):
                    count += 1

    mode = "would rename" if dry_run else "renamed"
    print(f"\n{'🔍 Dry run:' if dry_run else '✅'} {mode} {count} files")
    if dry_run and count:
        print(f"   Run {BOLD}pm rename --all{RESET} (without --dry-run) to apply.")


# ── Task Lifecycle Commands ────────────────────────────────────────────────


def _move_task(task_name, target_status, updates, label, icon):
    """Shared logic for moving a task to a new status directory."""
    path = find_task(task_name)
    if not path:
        print(f"❌ Task not found: {task_name}")
        return False

    print(f"{icon} {label}: {path.name}")
    updates["updated_at"] = datetime.date.today().isoformat()
    new_content = update_front_matter(path.read_text(), updates)
    target = STATUS_DIRS[target_status] / path.name

    if target.exists() and target.resolve() != path.resolve():
        print(f"⚠️  Already exists in {target_status}: {target.name}")
        return False

    path.write_text(new_content)
    if path.resolve() != target.resolve():
        git_mv(path, target)
    git_add(target)
    print(f"✅ → tasks/{target_status}/{path.name}")
    return True


def cmd_start(args):
    """Move task(s) to in-progress."""
    today = datetime.date.today().isoformat()
    for task in args.tasks:
        _move_task(
            task,
            "in-progress",
            {"status": "in-progress", "started_at": today},
            "Starting",
            "🚀",
        )


def cmd_complete(args):
    """Move task(s) to completed."""
    today = datetime.date.today().isoformat()
    for task in args.tasks:
        _move_task(
            task,
            "completed",
            {"status": "completed", "completed_at": today},
            "Completing",
            "🎉",
        )
    if getattr(args, "recommend", False):
        cmd_recommend(args)


def cmd_deprecate(args):
    """Move task(s) to deprecated."""
    today = datetime.date.today().isoformat()
    reason = getattr(args, "reason", None)
    updates = {"status": "deprecated", "deprecated_at": today}
    if reason:
        updates["deprecated_reason"] = reason
    for task in args.tasks:
        _move_task(task, "deprecated", updates, "Deprecating", "🗑️ ")


def cmd_defer(args):
    """Defer task(s) — soft pause, not deprecation."""
    reason = getattr(args, "reason", None) or "deferred"
    revisit = getattr(args, "revisit", None)
    if revisit and _parse_iso_date(revisit) is None:
        print(f"❌ --revisit must be YYYY-MM-DD, got '{revisit}'")
        return
    updates = {
        "status": "deferred",
        "deferred_at": datetime.date.today().isoformat(),
        "deferred_reason": reason,
    }
    if revisit:
        updates["revisit_after"] = revisit
    for task in args.tasks:
        _move_task(task, "deprecated", updates, "Deferring", "⏸️ ")
    if revisit:
        print(f"   Revisit on/after: {revisit} (surfaces in `pm` dashboard when due)")


def cmd_next(args):
    """Move task(s) to next-up."""
    for task in args.tasks:
        _move_task(task, "next-up", {"status": "next-up"}, "Moving to Next Up", "🚀")


def cmd_promote(args):
    """Promote ready-to-start task(s) → next-up (guard-railed; idempotent)."""
    for task in args.tasks:
        path = find_task(task)
        if not path:
            print(f"❌ Task not found: {task}")
            continue
        cur = path.parent.name
        if cur == "next-up":
            print(f"✓ Already in next-up: {path.name} (no-op)")
            continue
        if cur != "ready-to-start":
            print(
                f"❌ Refusing to promote {path.name}: in '{cur}', not "
                f"'ready-to-start'. Use pm start/defer or move it manually."
            )
            continue
        _move_task(task, "next-up", {"status": "next-up"}, "Promoting", "⬆️ ")


def cmd_demote(args):
    """Demote next-up task(s) → ready-to-start (guard-railed; idempotent)."""
    for task in args.tasks:
        path = find_task(task)
        if not path:
            print(f"❌ Task not found: {task}")
            continue
        cur = path.parent.name
        if cur == "ready-to-start":
            print(f"✓ Already in ready-to-start: {path.name} (no-op)")
            continue
        if cur != "next-up":
            print(f"❌ Refusing to demote {path.name}: in '{cur}', not 'next-up'.")
            continue
        _move_task(
            task, "ready-to-start", {"status": "ready-to-start"}, "Demoting", "⬇️ "
        )


def cmd_new(args):
    """Create a new task file with validated frontmatter."""
    # Validate epic
    valid_epics = get_valid_epics()
    if valid_epics and args.epic not in valid_epics:
        # Try partial match
        matches = [e for e in valid_epics if args.epic in e]
        if len(matches) == 1:
            args.epic = matches[0]
            print(f"   Matched epic: {args.epic}")
        elif matches:
            print(f"❌ Ambiguous epic '{args.epic}'. Matches: {', '.join(matches)}")
            return
        else:
            print(f"❌ Unknown epic: {args.epic}")
            print(f"   Valid epics: {', '.join(valid_epics)}")
            return

    # Validate tier
    try:
        tier = int(args.tier)
        if tier < 1 or tier > 5:
            print(f"❌ Tier must be 1-5, got {tier}")
            return
    except ValueError:
        print(f"❌ Tier must be a number 1-5, got '{args.tier}'")
        return

    # Validate priority
    valid_priorities = ("high", "medium", "low")
    if args.priority not in valid_priorities:
        print(f"❌ Priority must be one of: {', '.join(valid_priorities)}")
        return

    # Validate autonomy
    try:
        autonomy = int(args.autonomy) if args.autonomy else 3
        if autonomy < 1 or autonomy > 5:
            print(f"❌ Autonomy must be 1-5, got {autonomy}")
            return
    except ValueError:
        print(f"❌ Autonomy must be a number 1-5, got '{args.autonomy}'")
        return

    slug = slugify(args.title) + ".md"
    target_dir = STATUS_DIRS["next-up"] if args.next else STATUS_DIRS["ready-to-start"]
    status = target_dir.name
    path = target_dir / slug

    if path.exists():
        print(f"❌ Already exists: {path.relative_to(PLANNING_DIR)}")
        return

    tags = []
    if args.tags:
        tags = [t.strip() for t in args.tags.split(",")]

    # Build body
    body_text = getattr(args, "body", None)
    if body_text:
        body = f"# {args.title}\n\n{body_text}\n"
    else:
        body = f"# {args.title}\n\n## Objective\n\n{args.title}\n\n## Implementation Plan\n\n- [ ] TBD\n"

    content = serialize_front_matter(
        {
            "status": status,
            "epic": args.epic,
            "description": getattr(args, "description", "") or "",
            "effort": args.effort,
            "tier": tier,
            "priority": args.priority,
            "autonomy_level": autonomy,
            "tags": tags,
            "created": datetime.date.today().isoformat(),
        },
        body,
    )

    path.write_text(content)
    git_add(path)
    print(f"✅ Created: {path.relative_to(PLANNING_DIR)}")

    # Open in $EDITOR if --edit flag and running interactively
    if getattr(args, "edit", False) and sys.stdin.isatty():
        editor = os.environ.get("EDITOR", os.environ.get("VISUAL", "vi"))
        subprocess.call([editor, str(path)])


# ── ADR Commands ───────────────────────────────────────────────────────────


def cmd_adr_list(args):
    """List Architecture Decision Records from the implementation repo."""
    adr_dir = ADR_DIR
    if not adr_dir.exists():
        # Also check planning repo research/ for informal ADRs
        print(
            f"{DIM}No formal ADR directory at {adr_dir.relative_to(PLANNING_DIR.parent)}{RESET}"
        )
        print(f"Research docs in {RESEARCH_DIR.relative_to(PLANNING_DIR)}:")
        if RESEARCH_DIR.exists():
            for f in sorted(RESEARCH_DIR.glob("*.md")):
                print(f"  {f.name}")
        print(f'\n{DIM}Create formal ADRs with: pm adr new "Title"{RESET}')
        return

    adrs = sorted(adr_dir.glob("*.md"))
    if not adrs:
        print("No ADRs found.")
        return

    print(f"\n{BOLD}Architecture Decision Records{RESET}")
    print(f"{DIM}{adr_dir.relative_to(PLANNING_DIR.parent)}{RESET}\n")
    for f in adrs:
        meta, body = parse_front_matter(f.read_text())
        status = meta.get("status", "")
        title = meta.get("title", f.stem)
        status_badge = f" [{status}]" if status else ""
        print(f"  {f.stem:<40} {title}{status_badge}")


def cmd_adr_new(args):
    """Create a new ADR in the implementation repo."""
    adr_dir = ADR_DIR
    adr_dir.mkdir(parents=True, exist_ok=True)

    # Find next number
    existing = sorted(adr_dir.glob("*.md"))
    if existing:
        last_num = 0
        for f in existing:
            m = re.match(r"^(\d+)-", f.name)
            if m:
                last_num = max(last_num, int(m.group(1)))
        next_num = last_num + 1
    else:
        next_num = 1

    slug = slugify(args.title)
    filename = f"{next_num:04d}-{slug}.md"
    path = adr_dir / filename

    today = datetime.date.today().isoformat()
    content = f"""---
title: {args.title}
status: proposed
date: {today}
---

# {next_num}. {args.title}

## Status

Proposed

## Context

<!-- What is the issue that we're seeing that is motivating this decision or change? -->

## Decision

<!-- What is the change that we're proposing and/or doing? -->

## Consequences

<!-- What becomes easier or more difficult to do because of this change? -->
"""
    path.write_text(content)
    print(f"✅ Created ADR: {path.relative_to(PLANNING_DIR.parent)}")
    print(f"   Edit: {path}")

    # Also try to git add in the implementation repo
    try:
        subprocess.run(["git", "add", str(path)], capture_output=True, cwd=IMPL_DIR)
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass


# ── Recommend / Project Commands ───────────────────────────────────────────


def cmd_recommend(args):
    """Generate RECOMMENDATIONS.md."""
    print("🔄 Generating RECOMMENDATIONS.md…")
    tasks = list(get_all_tasks(include_completed=False))
    tasks.sort(
        key=lambda t: (
            0
            if t["_status"] == "next-up"
            else 1
            if t["_status"] == "in-progress"
            else 2,
            int(t.get("tier", 9)),
        )
    )

    lines = [
        "# Recommended Focus\n",
        f"Generated: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}\n",
    ]

    next_up = [t for t in tasks if t["_status"] == "next-up"]
    in_progress = [t for t in tasks if t["_status"] == "in-progress"]

    if in_progress:
        lines.append("## In Progress\n")
        for t in in_progress:
            lines.append(
                f"- **{t['_filename']}** (Tier {t.get('tier', '?')} | A{t.get('autonomy_level', '?')})"
            )
        lines.append("")

    if next_up:
        lines.append("## Next Up\n")
        for t in next_up:
            lines.append(
                f"- **{t['_filename']}** (Tier {t.get('tier', '?')} | A{t.get('autonomy_level', '?')})"
            )
        lines.append("")

    top_ready = [
        t
        for t in tasks
        if t["_status"] == "ready-to-start" and int(t.get("tier", 9)) <= 2
    ][:10]
    if top_ready:
        lines.append("## Top Ready Candidates\n")
        for t in top_ready:
            lines.append(
                f"- {t['_filename']} (Tier {t.get('tier', '?')} | A{t.get('autonomy_level', '?')} | {t.get('epic', '?')})"
            )
        lines.append("")

    RECOMMENDATIONS_FILE.write_text("\n".join(lines))
    print(f"✅ Updated {RECOMMENDATIONS_FILE.relative_to(PLANNING_DIR)}")


def cmd_project_list(args):
    """List active projects."""
    tasks = list(get_all_tasks(include_completed=False))
    projects = {}
    for t in tasks:
        p = t.get("project")
        if p:
            projects.setdefault(p, []).append(t)
    if not projects:
        print("No active projects. Use 'pm project start <name>' to create one.")
        return
    print(f"\n🚀 {BOLD}ACTIVE PROJECTS{RESET}")
    for p, ptasks in projects.items():
        print(f"\n📁 {BOLD}{p}{RESET} ({len(ptasks)} tasks)")
        for t in ptasks:
            icon = "🏃" if t["_status"] == "in-progress" else "•"
            print(f"  {icon} {t['_filename']}")


# ── Index / Dashboard ──────────────────────────────────────────────────────


def cmd_index(args):
    """Show a cross-cutting dashboard: what's hot, what's blocked, what's stale."""
    # Include deprecated so deferred tasks with a due revisit_after surface here too.
    tasks = list(get_all_tasks(include_completed=False, include_deprecated=True))
    today = datetime.date.today()

    # Split active tasks by revisit_after state. A waiting task is excluded
    # from the "active In Progress" view because it's intentionally idle.
    revisit_due = []  # revisit_after <= today  (across any non-completed status)
    revisit_waiting = []  # revisit_after >  today  (next-up / in-progress only)

    for t in tasks:
        state, when = _revisit_state(t, today)
        if state == "due":
            revisit_due.append((t, when))
        elif state == "waiting" and t["_status"] in ("next-up", "in-progress"):
            revisit_waiting.append((t, when))

    waiting_files = {t["_filename"] for t, _ in revisit_waiting}

    in_progress = [
        t
        for t in tasks
        if t["_status"] == "in-progress" and t["_filename"] not in waiting_files
    ]
    next_up = [
        t
        for t in tasks
        if t["_status"] == "next-up" and t["_filename"] not in waiting_files
    ]

    # Stale: in-progress (active) with no recent update — skip "waiting" ones.
    stale = []
    for t in in_progress:
        ref = (
            t.get("updated_at")
            or t.get("started_at")
            or t.get("started_date")
            or t.get("created")
            or t.get("created_date")
        )
        d = _parse_iso_date(ref)
        if d and (today - d).days > 14:
            stale.append((t, (today - d).days))

    # Quick wins
    quick_wins = []
    for t in tasks:
        if t["_status"] == "ready-to-start":
            tier = str(t.get("tier", "9"))
            auto = str(t.get("autonomy_level", "0"))
            if tier in ("1", "2") and auto in ("4", "5"):
                quick_wins.append(t)

    if getattr(args, "json", False):
        print(
            json.dumps(
                {
                    "ready_to_revisit": [
                        {
                            "file": t["_filename"],
                            "status": t["_status"],
                            "revisit_after": str(when),
                            "reason": t.get("revisit_reason", ""),
                        }
                        for t, when in sorted(revisit_due, key=lambda x: x[1])
                    ],
                    "waiting_on_revisit": [
                        {
                            "file": t["_filename"],
                            "status": t["_status"],
                            "revisit_after": str(when),
                            "days_until": (when - today).days,
                            "reason": t.get("revisit_reason", ""),
                        }
                        for t, when in sorted(revisit_waiting, key=lambda x: x[1])
                    ],
                    "in_progress": [t["_filename"] for t in in_progress],
                    "next_up": [t["_filename"] for t in next_up],
                    "stale": [{"file": t["_filename"], "days": d} for t, d in stale],
                    "quick_wins": [t["_filename"] for t in quick_wins],
                },
                indent=2,
                default=str,
            )
        )
        return

    print(f"\n{BOLD}📋 DASHBOARD{RESET}  ({today.isoformat()})")

    # Surface revisit-ready work near the top — these are tasks the user
    # explicitly time-gated and the gate has now passed.
    if revisit_due:
        print(
            f"\n  {BOLD}{GREEN}✅ Ready to revisit ({len(revisit_due)}){RESET} — "
            f"time-gated tasks now due"
        )
        for t, when in sorted(revisit_due, key=lambda x: x[1]):
            overdue = (today - when).days
            ago = f"due today" if overdue == 0 else f"{overdue}d overdue"
            reason = t.get("revisit_reason", "")
            line = f"     {t['_filename']:<50} {GREY}{t['_status']}{RESET}  {GREEN}{ago}{RESET}"
            print(line)
            if reason:
                print(f"     {DIM}↳ {str(reason)[:90]}{RESET}")

    if in_progress:
        print(f"\n  {BOLD}🏃 In Progress ({len(in_progress)}){RESET}")
        for t in in_progress:
            epic = t.get("epic", "")
            print(f"     {t['_filename']:<50} {GREY}{epic}{RESET}")

    if next_up:
        print(f"\n  {BOLD}🚀 Next Up ({len(next_up)}){RESET}")
        for t in next_up:
            tier = str(t.get("tier", "·"))
            print(f"     {t['_filename']:<50} T{tier}")

    if revisit_waiting:
        print(
            f"\n  {BOLD}{CYAN}⏳ Waiting ({len(revisit_waiting)}){RESET} — "
            f"time-gated, not yet due"
        )
        for t, when in sorted(revisit_waiting, key=lambda x: x[1]):
            days = (when - today).days
            print(f"     {t['_filename']:<50} {CYAN}revisit {when} ({days}d){RESET}")

    if stale:
        print(
            f"\n  {BOLD}{YELLOW}⏰ Stale ({len(stale)}){RESET} — no update in > 14 days"
        )
        for t, days in sorted(stale, key=lambda x: -x[1]):
            print(f"     {t['_filename']:<50} {YELLOW}{days}d{RESET}")

    if quick_wins:
        print(
            f"\n  {BOLD}{GREEN}⚡ Quick Wins ({len(quick_wins)}){RESET} — T1-2, high autonomy"
        )
        for t in quick_wins[:5]:
            print(f"     {t['_filename']}")

    total_active = len(
        [
            t
            for t in tasks
            if t["_status"] in ("next-up", "in-progress", "ready-to-start")
        ]
    )
    print(
        f"\n  {DIM}Active backlog: {total_active} tasks across "
        f"{len(set(t.get('epic') for t in tasks))} epics{RESET}"
    )
    if revisit_due or revisit_waiting:
        print(
            f"  {DIM}Filter: pm list --due (ready) · pm list --waiting (gated){RESET}"
        )


# ── Main ───────────────────────────────────────────────────────────────────


def main():
    parser = argparse.ArgumentParser(
        description="Desirelines Project Manager",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Task lifecycle:
              new       Create a task
              start     Move to in-progress
              next      Move to next-up
              complete  Move to completed
              deprecate Move to deprecated
              defer     Soft-pause a task
              touch     Update updated_at

            Query:
              list      List/filter tasks        (--json/--oneline; --due/--waiting)
              show      Show a single task        (--json for machine output)
              stats     Project-wide statistics
              tags      Show tag vocabulary
              index     Dashboard: ready-to-revisit, hot, waiting, stale, quick wins

            Epic management:
              epic list     List epics with task rollup + description
              epic show     Show epic details + tasks
              epic new      Create a new epic with standard frontmatter
              epic lint     Validate epic frontmatter (--fix for alias renames)
              epic orphans  Tasks referencing unknown epic IDs

            Schema:
              lint      Validate task frontmatter (--fix; --include-archived)
              schema    Print frontmatter schema (--type task|epic|all; --json)
              set       Set a frontmatter field
              rename    Normalize filenames      (--all --dry-run)

            ADR:
              adr list  List architecture decision records
              adr new   Create a new ADR

            Other:
              recommend  Generate RECOMMENDATIONS.md
              project    Manage cross-cutting projects
        """),
    )

    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # ── list ──
    lp = subparsers.add_parser("list", help="List/filter tasks")
    lp.add_argument(
        "--status",
        choices=[
            "next-up",
            "in-progress",
            "ready-to-start",
            "completed",
            "deprecated",
            "all",
        ],
    )
    lp.add_argument("--tag", help="Filter by tag")
    lp.add_argument("--epic", help="Filter by epic ID")
    lp.add_argument("--tier", help="Filter by tier (1-5)")
    lp.add_argument("--priority", help="Filter by priority (high/medium/low)")
    lp.add_argument("--autonomy", help="Filter by autonomy level (1-5)")
    lp.add_argument("--package", help="Filter by implementation package")
    lp.add_argument("--search", help="Full-text search")
    lp.add_argument(
        "--quick-wins", action="store_true", help="High-impact, low-effort tasks"
    )
    lp.add_argument(
        "--due",
        action="store_true",
        help="Tasks with revisit_after on/before today (ready to revisit)",
    )
    lp.add_argument(
        "--waiting",
        action="store_true",
        help="Tasks with revisit_after in the future (time-gated)",
    )
    lp.add_argument(
        "--oneline",
        action="store_true",
        help="One line per task with description (scan-friendly)",
    )
    lp.add_argument("--limit", type=int, default=50, help="Max results (default: 50)")
    lp.add_argument(
        "--json", action="store_true", help="JSON output for AI consumption"
    )

    # ── show ──
    sp = subparsers.add_parser("show", help="Show task details")
    sp.add_argument("task", help="Task name or slug")
    sp.add_argument("--json", action="store_true", help="JSON output")

    # ── stats ──
    stp = subparsers.add_parser("stats", help="Project statistics")
    stp.add_argument("--json", action="store_true", help="JSON output")

    # ── tags ──
    tgp = subparsers.add_parser("tags", help="Show tag vocabulary")
    tgp.add_argument("--json", action="store_true", help="JSON output")

    # ── index ──
    ip = subparsers.add_parser("index", help="Dashboard: hot, stale, quick wins")
    ip.add_argument("--json", action="store_true", help="JSON output")

    # ── epic ──
    ep = subparsers.add_parser("epic", help="Epic management")
    ep_sub = ep.add_subparsers(dest="epic_command")
    elp = ep_sub.add_parser("list", help="List epics with task counts")
    elp.add_argument("--json", action="store_true", help="JSON output")
    esp = ep_sub.add_parser("show", help="Show epic details + tasks")
    esp.add_argument("epic_id", help="Epic ID (e.g., 03-frontend or just 03)")
    esp.add_argument("--json", action="store_true", help="JSON output")
    elintp = ep_sub.add_parser("lint", help="Validate epic frontmatter")
    elintp.add_argument("--fix", action="store_true", help="Auto-apply alias renames")
    enp = ep_sub.add_parser(
        "new", help="Create a new epic with standardized frontmatter"
    )
    enp.add_argument("title", help="Epic title (used for filename slug + H1)")
    enp.add_argument(
        "--description",
        "--desc",
        dest="description",
        required=True,
        help="One-line goal summary (≤150 chars)",
    )
    enp.add_argument("--tags", default="", help="Comma-separated tags")
    enp.add_argument(
        "--status", default="planning", help="Initial status (default: planning)"
    )
    enp.add_argument("--priority", default="medium", help="Priority (default: medium)")
    enp.add_argument("--owner", default="", help="Optional owner")
    eop = ep_sub.add_parser("orphans", help="List tasks referencing unknown epics")
    eop.add_argument(
        "--include-archived",
        action="store_true",
        help="Include completed/deprecated tasks",
    )
    eop.add_argument("--json", action="store_true", help="JSON output")

    # ── set ──
    setp = subparsers.add_parser("set", help="Set a frontmatter field")
    setp.add_argument("task", help="Task name or slug")
    setp.add_argument("field", help="Field name")
    setp.add_argument("value", help="Field value")

    # ── lint ──
    lintp = subparsers.add_parser("lint", help="Validate task frontmatter")
    lintp.add_argument(
        "tasks", nargs="*", help="Lint only these task(s) (default: all active)"
    )
    lintp.add_argument("--fix", action="store_true", help="Auto-repair common issues")
    lintp.add_argument(
        "--include-archived",
        action="store_true",
        help="Include completed/deprecated tasks",
    )
    lintp.add_argument(
        "--errors-only",
        action="store_true",
        help="Suppress advisory blocks; show only hard errors",
    )
    lintp.add_argument(
        "--no-handoff-check",
        action="store_true",
        help="Skip the fresh-AI-handoff body advisory",
    )

    # ── schema ──
    schp = subparsers.add_parser(
        "schema", help="Print the frontmatter schema (task and/or epic)"
    )
    schp.add_argument(
        "--type",
        choices=["task", "epic", "all"],
        default="task",
        help="Which schema to print (default: task)",
    )
    schp.add_argument("--json", action="store_true", help="JSON output")

    # ── rename ──
    rnp = subparsers.add_parser("rename", help="Normalize task filenames")
    rnp.add_argument(
        "task", nargs="?", default="--all", help="Task to rename (or --all)"
    )
    rnp.add_argument(
        "--all",
        action="store_true",
        dest="rename_all",
        help="Rename all problematic files",
    )
    rnp.add_argument(
        "--dry-run", action="store_true", help="Preview without changing files"
    )

    # ── touch ──
    tp = subparsers.add_parser("touch", help="Update updated_at for tasks")
    tp.add_argument("tasks", nargs="+", help="Task name(s)")

    # ── lifecycle (all accept multiple tasks) ──
    subparsers.add_parser("start", help="Move task(s) to in-progress").add_argument(
        "tasks", nargs="+", help="Task name(s)"
    )
    subparsers.add_parser("next", help="Move task(s) to next-up").add_argument(
        "tasks", nargs="+", help="Task name(s)"
    )
    subparsers.add_parser(
        "promote", help="Promote ready-to-start task(s) → next-up"
    ).add_argument("tasks", nargs="+", help="Task name(s)")
    subparsers.add_parser(
        "demote", help="Demote next-up task(s) → ready-to-start"
    ).add_argument("tasks", nargs="+", help="Task name(s)")

    cp = subparsers.add_parser("complete", help="Complete task(s)")
    cp.add_argument("tasks", nargs="+", help="Task name(s)")
    cp.add_argument(
        "--recommend", action="store_true", help="Regenerate recommendations"
    )

    dp = subparsers.add_parser("deprecate", help="Deprecate task(s)")
    dp.add_argument("tasks", nargs="+", help="Task name(s)")
    dp.add_argument("--reason", help="Reason for deprecation")

    dfp = subparsers.add_parser("defer", help="Defer task(s) (soft pause)")
    dfp.add_argument("tasks", nargs="+", help="Task name(s)")
    dfp.add_argument("--reason", help="Why deferred")
    dfp.add_argument("--revisit", help="Date to revisit (YYYY-MM-DD)")

    # ── new ──
    np = subparsers.add_parser("new", help="Create a new task")
    np.add_argument("title", help="Task title")
    np.add_argument("--epic", required=True, help="Epic ID")
    np.add_argument("--effort", default="Unknown", help="Effort estimate")
    np.add_argument("--tier", default="3", help="Tier (1-5)")
    np.add_argument("--priority", default="medium", help="Priority")
    np.add_argument("--autonomy", default="3", help="Autonomy level (1-5)")
    np.add_argument("--tags", default="", help="Comma-separated tags")
    np.add_argument(
        "--description",
        "--desc",
        dest="description",
        default="",
        help="One-line summary (shown in list --json/--oneline)",
    )
    np.add_argument(
        "--next",
        action="store_true",
        help="Create in next-up instead of ready-to-start",
    )
    np.add_argument("--body", help="Task body text (replaces boilerplate)")
    np.add_argument(
        "--edit", action="store_true", help="Open in $EDITOR after creation"
    )

    # ── adr ──
    adp = subparsers.add_parser("adr", help="Architecture Decision Records")
    adr_sub = adp.add_subparsers(dest="adr_command")
    adr_sub.add_parser("list", help="List ADRs")
    adr_np = adr_sub.add_parser("new", help="Create a new ADR")
    adr_np.add_argument("title", help="ADR title")

    # ── recommend ──
    subparsers.add_parser("recommend", help="Generate RECOMMENDATIONS.md")

    # ── validate (alias for lint) ──
    vp = subparsers.add_parser("validate", help="Alias for lint")
    vp.add_argument(
        "tasks", nargs="*", help="Lint only these task(s) (default: all active)"
    )
    vp.add_argument("--fix", action="store_true", help="Auto-repair common issues")
    vp.add_argument(
        "--include-archived",
        action="store_true",
        help="Include completed/deprecated tasks",
    )
    vp.add_argument(
        "--errors-only",
        action="store_true",
        help="Suppress advisory blocks; show only hard errors",
    )
    vp.add_argument(
        "--no-handoff-check",
        action="store_true",
        help="Skip the fresh-AI-handoff body advisory",
    )

    # ── project ──
    pp = subparsers.add_parser("project", help="Manage projects")
    pp_sub = pp.add_subparsers(dest="project_command")
    pp_sub.add_parser("list", help="List active projects")

    # ── Parse and dispatch ──
    args = parser.parse_args()

    # Stateless source-of-truth nudge → stderr only, so it never corrupts
    # machine-readable stdout. Suppressed for --json and via PM_QUIET=1.
    if not os.environ.get("PM_QUIET") and "--json" not in sys.argv:
        print(
            f"{DIM}ℹ AI_README.md is the source of truth — read it before "
            f"multi-step work (silence: PM_QUIET=1).{RESET}",
            file=sys.stderr,
        )

    commands = {
        "list": cmd_list,
        "show": cmd_show,
        "stats": cmd_stats,
        "tags": cmd_tags,
        "index": cmd_index,
        "set": cmd_set,
        "touch": cmd_touch,
        "lint": cmd_lint,
        "validate": cmd_lint,
        "schema": cmd_schema,
        "rename": lambda a: cmd_rename(a),
        "start": cmd_start,
        "complete": cmd_complete,
        "deprecate": cmd_deprecate,
        "defer": cmd_defer,
        "next": cmd_next,
        "promote": cmd_promote,
        "demote": cmd_demote,
        "new": cmd_new,
        "recommend": cmd_recommend,
    }

    if args.command == "epic":
        if args.epic_command == "list":
            cmd_epic_list(args)
        elif args.epic_command == "show":
            cmd_epic_show(args)
        elif args.epic_command == "lint":
            cmd_epic_lint(args)
        elif args.epic_command == "new":
            cmd_epic_new(args)
        elif args.epic_command == "orphans":
            cmd_epic_orphans(args)
        else:
            parser.parse_args(["epic", "--help"])
    elif args.command == "adr":
        if args.adr_command == "list":
            cmd_adr_list(args)
        elif args.adr_command == "new":
            cmd_adr_new(args)
        else:
            parser.parse_args(["adr", "--help"])
    elif args.command == "project":
        if args.project_command == "list":
            cmd_project_list(args)
        else:
            parser.parse_args(["project", "--help"])
    elif args.command in commands:
        commands[args.command](args)
    elif args.command is None:
        # Default: show index dashboard
        cmd_index(argparse.Namespace(json=False))
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
