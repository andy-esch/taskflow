# ── Configuration ──────────────────────────────────────────────────────────

PLANNING_DIR = Path(__file__).resolve().parent.parent / "planning"
TASKS_DIR = PLANNING_DIR / "tasks"
EPICS_DIR = PLANNING_DIR / "epics"
RESEARCH_DIR = PLANNING_DIR / "research"
RECOMMENDATIONS_FILE = PLANNING_DIR / "RECOMMENDATIONS.md"


def _load_config():
    """Load .pm.toml config, falling back to env vars, then defaults."""
    config = {
        "impl_dir": PLANNING_DIR.parent / "desirelines",
        "deploy_dir": PLANNING_DIR.parent / "desirelines-deploy",
        "adr_subpath": "docs/adr",
    }
    # .pm.toml in planning repo root
    toml_path = PLANNING_DIR / ".pm.toml"
    if toml_path.exists() and tomllib:
        with open(toml_path, "rb") as f:
            raw = tomllib.load(f)
        repos = raw.get("repos", {})
        if repos.get("impl"):
            config["impl_dir"] = Path(repos["impl"]).expanduser().resolve()
        if repos.get("deploy"):
            config["deploy_dir"] = Path(repos["deploy"]).expanduser().resolve()
        if repos.get("adr_subpath"):
            config["adr_subpath"] = repos["adr_subpath"]
    # Env vars override config file
    if os.environ.get("DESIRELINES_IMPL"):
        config["impl_dir"] = Path(os.environ["DESIRELINES_IMPL"]).expanduser().resolve()
    if os.environ.get("DESIRELINES_DEPLOY"):
        config["deploy_dir"] = (
            Path(os.environ["DESIRELINES_DEPLOY"]).expanduser().resolve()
        )
    return config


_CONFIG = _load_config()
