    "started_date": "started_at",
    "created_date": "created",
    "summary": "description",
    "desc": "description",
}

# Frontmatter fields that must be YAML lists of scalar strings. A list item
# carrying a colon (e.g. `- some-task: with-colon`) silently parses as a
# mapping, mangling the field — see `_list_field_issues`.
