    "audit_sources",
]

# Fields that have constrained values (for pm set validation).
CONSTRAINED_FIELDS = {
    "status": (
        "one of: " + ", ".join(sorted(VALID_STATUSES)),
        lambda v: v in VALID_STATUSES,
    ),
    "priority": ("one of: high, medium, low", lambda v: v in VALID_PRIORITIES),
    "tier": ("integer 1-5", lambda v: v.isdigit() and int(v) in VALID_TIERS),
    "autonomy_level": (
        "integer 1-5",
        lambda v: v.isdigit() and int(v) in VALID_AUTONOMY,
    ),
    "epic": (
        "valid epic ID",
        lambda v: not get_valid_epics() or v in get_valid_epics(),
    ),
    "revisit_after": (
        "date in YYYY-MM-DD format",
        lambda v: bool(re.match(r"^\d{4}-\d{2}-\d{2}$", str(v))),
    ),
}

