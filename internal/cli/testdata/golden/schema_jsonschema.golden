    "VersionEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "version"
      ],
      "description": "VersionEnvelope is `version --json`."
    },
    "jsonEnvelopes": {
      "properties": {
        "tasks": {
          "$ref": "#/$defs/TasksEnvelope"
        },
        "task_show": {
