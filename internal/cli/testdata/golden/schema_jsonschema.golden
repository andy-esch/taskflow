{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/andy-esch/taskflow/internal/wire/json-envelopes",
  "$ref": "#/$defs/jsonEnvelopes",
  "$defs": {
    "AuditJSON": {
      "properties": {
        "slug": {
          "type": "string",
          "description": "audit identifier (filename without .md)"
        },
        "bucket": {
          "type": "string",
          "description": "open | closed | deferred — equals the audit's directory"
        },
        "area": {
          "type": "string",
          "description": "subsystem/topic audited"
        },
        "date": {
          "type": "string",
          "description": "audit date YYYY-MM-DD"
        },
        "findings": {
          "type": "integer",
          "description": "total findings parsed from the body"
        },
        "open_findings": {
          "type": "integer",
          "description": "findings whose status is open"
        },
        "in_progress_findings": {
          "type": "integer",
          "description": "findings whose status is in-progress"
        },
        "done_findings": {
          "type": "integer",
          "description": "findings whose status is fixed or landed (the bar's done band)"
        },
        "dropped_findings": {
          "type": "integer",
          "description": "findings whose status is deferred"
        },
        "ready_to_close": {
          "type": "boolean",
          "description": "true when an open audit has no open/in-progress findings left (ready to close)"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slug",
        "bucket",
        "findings",
        "open_findings",
        "in_progress_findings",
        "done_findings",
        "dropped_findings"
      ],
      "description": "AuditJSON is the wire shape of an audit inside the --json envelopes."
    },
    "AuditShowEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "audit": {
          "$ref": "#/$defs/AuditJSON"
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "audit",
        "body"
      ],
      "description": "AuditShowEnvelope is `audit show --json`."
    },
    "AuditsEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "audits": {
          "items": {
            "$ref": "#/$defs/AuditJSON"
          },
          "type": "array"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "audits"
      ],
      "description": "AuditsEnvelope is `audit list --json`."
    },
    "CountByJSON": {
      "properties": {
        "key": {
          "type": "string",
          "description": "the urgency value or top-level component"
        },
        "count": {
          "type": "integer",
          "description": "actionable findings in this bucket"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "key",
        "count"
      ],
      "description": "CountByJSON is one bucket of a finding breakdown — an urgency value or a top-level component, and its count."
    },
    "CreatedEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "created": {
          "$ref": "#/$defs/CreatedItem"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "created"
      ],
      "description": "CreatedEnvelope is `task/epic/audit new --json`."
    },
    "CreatedItem": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "id",
        "status",
        "path"
      ],
      "description": "CreatedItem is the created document inside CreatedEnvelope."
    },
    "DoctorEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "problems": {
          "items": {
            "$ref": "#/$defs/DoctorProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "root",
        "problems"
      ],
      "description": "DoctorEnvelope is `doctor --json`: the linkback audit result."
    },
    "DoctorProblem": {
      "properties": {
        "repo": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "repo",
        "message"
      ],
      "description": "DoctorProblem is one linkback inconsistency: the offending repo + a message."
    },
    "EpicJSON": {
      "properties": {
        "id": {
          "type": "string",
          "description": "epic identifier (NN-slug)"
        },
        "status": {
          "type": "string",
          "description": "active | retired | deprecated"
        },
        "description": {
          "type": "string",
          "description": "one-line epic goal"
        },
        "priority": {
          "type": "string",
          "description": "high | medium | low"
        },
        "created": {
          "type": "string",
          "description": "creation date YYYY-MM-DD"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "topical tags"
        },
        "total": {
          "type": "integer"
        },
        "done": {
          "type": "integer"
        },
        "open": {
          "type": "integer",
          "description": "Open is the pending workload (total − done); 0 = nothing in flight."
        },
        "percent": {
          "type": "integer"
        },
        "deprecated": {
          "type": "integer",
          "description": "Deprecated is the withdrawn tasks, excluded from total/done."
        },
        "liveness": {
          "type": "string",
          "description": "derived activity: working | fresh | dormant"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "total",
        "done",
        "open",
        "percent",
        "deprecated",
        "liveness"
      ],
      "description": "EpicJSON is epic list output: the shared meta (embedded, so `epic list` and `epic show` can't drift) plus the task rollup."
    },
    "EpicMetaJSON": {
      "properties": {
        "id": {
          "type": "string",
          "description": "epic identifier (NN-slug)"
        },
        "status": {
          "type": "string",
          "description": "active | retired | deprecated"
        },
        "description": {
          "type": "string",
          "description": "one-line epic goal"
        },
        "priority": {
          "type": "string",
          "description": "high | medium | low"
        },
        "created": {
          "type": "string",
          "description": "creation date YYYY-MM-DD"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "topical tags"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id"
      ],
      "description": "EpicMetaJSON is the shared epic meta fields, embedded by EpicJSON (`epic list`) and emitted directly by `epic show` / `epic set`."
    },
    "EpicMutationEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "epic": {
          "$ref": "#/$defs/EpicMetaJSON"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "epic"
      ],
      "description": "EpicMutationEnvelope is `epic set --json`: the reloaded epic + dry_run."
    },
    "EpicShowEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "epic": {
          "$ref": "#/$defs/EpicMetaJSON"
        },
        "tasks": {
          "items": {
            "$ref": "#/$defs/TaskJSON"
          },
          "type": "array"
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "epic",
        "tasks",
        "body"
      ],
      "description": "EpicShowEnvelope is `epic show --json`."
    },
    "EpicsEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "epics": {
          "items": {
            "$ref": "#/$defs/EpicJSON"
          },
          "type": "array"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "epics"
      ],
      "description": "EpicsEnvelope is `epic list --json`."
    },
    "ErrorEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "error": {
          "$ref": "#/$defs/ErrorItem"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "error"
      ],
      "description": "ErrorEnvelope is the failure payload emitted under --json (see cli.WriteError)."
    },
    "ErrorItem": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "description": "ErrorItem is the error body inside ErrorEnvelope."
    },
    "FieldDoc": {
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "example": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "type",
        "required",
        "description",
        "example"
      ],
      "description": "FieldDoc documents one *authoring* field: the human/agent-set frontmatter a well-formed document declares."
    },
    "FileProblem": {
      "properties": {
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "path",
        "message"
      ],
      "description": "FileProblem is a non-fatal per-file load problem: the file was skipped, with an actionable message explaining what's wrong and how to fix it."
    },
    "FindingJSON": {
      "properties": {
        "audit": {
          "type": "string",
          "description": "slug of the audit this finding belongs to"
        },
        "bucket": {
          "type": "string",
          "description": "the audit's bucket — open | closed | deferred"
        },
        "code": {
          "type": "string",
          "description": "finding code within the audit (H1/M2/S3…)"
        },
        "title": {
          "type": "string",
          "description": "finding title"
        },
        "status": {
          "type": "string",
          "description": "open | in-progress | fixed | landed | deferred | superseded | wontfix"
        },
        "file": {
          "type": "string",
          "description": "file:line the finding refers to"
        },
        "component": {
          "type": "string",
          "description": "component/subsystem"
        },
        "effort": {
          "type": "string",
          "description": "XS | S | M | L"
        },
        "urgency": {
          "type": "string",
          "description": "acute | soon | eventually"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "audit",
        "bucket",
        "code",
        "title",
        "status"
      ],
      "description": "FindingJSON is the wire shape of one audit finding."
    },
    "FindingsEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "findings": {
          "items": {
            "$ref": "#/$defs/FindingJSON"
          },
          "type": "array"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "findings"
      ],
      "description": "FindingsEnvelope is `audit findings --json` (the finding-level query)."
    },
    "FindingsRollupJSON": {
      "properties": {
        "open": {
          "type": "integer",
          "description": "actionable findings with status open"
        },
        "in_progress": {
          "type": "integer",
          "description": "actionable findings with status in-progress"
        },
        "by_urgency": {
          "items": {
            "$ref": "#/$defs/CountByJSON"
          },
          "type": "array",
          "description": "breakdown by urgency (acute"
        },
        "by_component": {
          "items": {
            "$ref": "#/$defs/CountByJSON"
          },
          "type": "array",
          "description": "breakdown by top-level component"
        },
        "acute": {
          "items": {
            "$ref": "#/$defs/FindingJSON"
          },
          "type": "array",
          "description": "the acute findings"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "open",
        "in_progress"
      ],
      "description": "FindingsRollupJSON aggregates the actionable audit findings (status open or in-progress) across all audits — the `status` summary's \"audit findings\" view."
    },
    "FixEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "fixed": {
          "items": {
            "$ref": "#/$defs/FixResult"
          },
          "type": "array"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        },
        "remaining": {
          "items": {
            "$ref": "#/$defs/LintTaskJSON"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "fixed",
        "unreadable",
        "remaining"
      ],
      "description": "FixEnvelope is `lint --fix --json`."
    },
    "FixResult": {
      "properties": {
        "path": {
          "type": "string"
        },
        "changes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "path",
        "changes"
      ],
      "description": "FixResult records the auto-repairs applied (or proposed) for one file."
    },
    "InitEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "mode": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "planning_repo": {
          "type": "string"
        },
        "linked_back": {
          "type": "string"
        },
        "tracked": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "created": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "mode",
        "root",
        "created"
      ],
      "description": "InitEnvelope is `init --json`."
    },
    "Issue": {
      "properties": {
        "field": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "field",
        "message"
      ],
      "description": "Issue is a single frontmatter lint finding."
    },
    "LintEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/LintTaskJSON"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "unreadable",
        "issues"
      ],
      "description": "LintEnvelope is `lint --json` and `audit lint --json` (the same per-entity slug+issues shape backs both)."
    },
    "LintTaskJSON": {
      "properties": {
        "slug": {
          "type": "string"
        },
        "issues": {
          "items": {
            "$ref": "#/$defs/Issue"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slug",
        "issues"
      ],
      "description": "LintTaskJSON is one entity's lint result (slug + field issues), the shape the `lint` / `audit lint` / `fix --remaining` envelopes carry per entity."
    },
    "MoveResult": {
      "properties": {
        "slug": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "revisit_at": {
          "type": "string",
          "description": "revisit (snooze-until) date recorded by task defer"
        },
        "error": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slug",
        "to"
      ],
      "description": "MoveResult is the per-item outcome of a transition."
    },
    "MovesEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "moves": {
          "items": {
            "$ref": "#/$defs/MoveResult"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "moves"
      ],
      "description": "MovesEnvelope is the transition report (`task start --json`, etc.)."
    },
    "SchemaEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "statuses": {
          "items": {
            "$ref": "#/$defs/SchemaStatus"
          },
          "type": "array"
        },
        "epic_statuses": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "audit_buckets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "task_fields": {
          "items": {
            "$ref": "#/$defs/SchemaField"
          },
          "type": "array"
        },
        "epic_fields": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "exit_codes": {
          "items": {
            "$ref": "#/$defs/SchemaExitCode"
          },
          "type": "array"
        },
        "kinds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "statuses",
        "epic_statuses",
        "audit_buckets",
        "task_fields",
        "epic_fields",
        "exit_codes",
        "kinds"
      ],
      "description": "SchemaEnvelope is `schema --json` (the global contract)."
    },
    "SchemaExitCode": {
      "properties": {
        "code": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "code",
        "name"
      ],
      "description": "SchemaExitCode is one exit code and its stable machine name (also the `code` in the --json error envelope)."
    },
    "SchemaField": {
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "description": "SchemaField is one known frontmatter field and its YAML storage type."
    },
    "SchemaKindEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "sections": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "body_template": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/FieldDoc"
          },
          "type": "array"
        },
        "conventions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "templates": {
          "items": {
            "$ref": "#/$defs/TemplateInfo"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "kind",
        "sections",
        "body_template",
        "fields",
        "conventions",
        "templates"
      ],
      "description": "SchemaKindEnvelope is `schema \u003ckind\u003e --json` (per-kind authoring guidance)."
    },
    "SchemaStatus": {
      "properties": {
        "value": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "value",
        "active"
      ],
      "description": "SchemaStatus is one task status and whether it is part of the working set."
    },
    "StatusCountJSON": {
      "properties": {
        "status": {
          "type": "string"
        },
        "count": {
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "status",
        "count"
      ],
      "description": "StatusCountJSON is one status bucket and its task count."
    },
    "SummaryEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "counts": {
          "items": {
            "$ref": "#/$defs/StatusCountJSON"
          },
          "type": "array"
        },
        "in_progress": {
          "items": {
            "$ref": "#/$defs/TaskJSON"
          },
          "type": "array"
        },
        "epics": {
          "items": {
            "$ref": "#/$defs/EpicJSON"
          },
          "type": "array"
        },
        "open_audits": {
          "items": {
            "$ref": "#/$defs/AuditJSON"
          },
          "type": "array"
        },
        "findings": {
          "$ref": "#/$defs/FindingsRollupJSON"
        },
        "misfiled": {
          "type": "integer"
        },
        "revisit_due": {
          "type": "integer"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "counts",
        "in_progress",
        "epics",
        "misfiled",
        "revisit_due"
      ],
      "description": "SummaryEnvelope is `status --json`."
    },
    "TaskJSON": {
      "properties": {
        "slug": {
          "type": "string",
          "description": "task identifier (filename without .md)"
        },
        "status": {
          "type": "string",
          "description": "lifecycle status — equals the task's directory under tasks/"
        },
        "epic": {
          "type": "string",
          "description": "id of the epic this task belongs to"
        },
        "description": {
          "type": "string",
          "description": "one-line summary (\u003c=200 chars)"
        },
        "effort": {
          "type": "string",
          "description": "free-form effort estimate"
        },
        "tier": {
          "type": "integer",
          "description": "importance 1 (highest) to 5 (lowest)"
        },
        "priority": {
          "type": "string",
          "description": "high | medium | low"
        },
        "autonomy_level": {
          "type": "integer",
          "description": "how autonomously this can be done 1-5"
        },
        "created": {
          "type": "string",
          "description": "creation date YYYY-MM-DD"
        },
        "updated_at": {
          "type": "string",
          "description": "last-modified date YYYY-MM-DD"
        },
        "revisit_at": {
          "type": "string",
          "description": "snooze-until date YYYY-MM-DD for a deferred task (set by task defer)"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "topical tags"
        },
        "misfiled": {
          "type": "boolean",
          "description": "Misfiled/Declared surface status≠folder drift to JSON consumers (agents\nare exactly who should detect it); declared_status only when misfiled."
        },
        "declared_status": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slug",
        "status"
      ],
      "description": "TaskJSON is the wire shape of a task inside the --json envelopes."
    },
    "TaskMutationEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "dry_run": {
          "type": "boolean"
        },
        "task": {
          "$ref": "#/$defs/TaskJSON"
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "dry_run",
        "task"
      ],
      "description": "TaskMutationEnvelope is `task set` / `task append` / `task set --body` under --json: the reloaded task, dry_run, and (for the body commands) the resulting body."
    },
    "TaskShowEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "task": {
          "$ref": "#/$defs/TaskJSON"
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "task",
        "body"
      ],
      "description": "TaskShowEnvelope is `task show --json`."
    },
    "TasksEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "tasks": {
          "items": {
            "$ref": "#/$defs/TaskJSON"
          },
          "type": "array"
        },
        "unreadable": {
          "items": {
            "$ref": "#/$defs/FileProblem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "tasks"
      ],
      "description": "TasksEnvelope is `task list --json`."
    },
    "TemplateInfo": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind",
        "name",
        "description"
      ],
      "description": "TemplateInfo is one body template's listable metadata (kind/name/description), populated by the cli for `template list`/`show`."
    },
    "TemplateShowEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "template": {
          "$ref": "#/$defs/TemplateInfo"
        },
        "body": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "schema_version",
        "template",
        "body"
      ],
      "description": "TemplateShowEnvelope is `template show --json` (a template's metadata + body)."
    },
    "TemplatesEnvelope": {
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "templates": {
